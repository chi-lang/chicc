# native/Makefile — Build the native chi executable
#
# Targets:
#   make              Build chi binary
#   make luajit       Download and build LuaJIT
#   make gen          Generate bytecode headers
#   make clean        Clean build artifacts
#   make distclean    Clean everything including vendor/
#   make install      Install to CHI_HOME/bin/
#
# Prerequisites: gcc, make, git

CC ?= gcc
CFLAGS = -O2 -Wall -Wextra -std=c99 -D_POSIX_C_SOURCE=200809L

# Paths
LUAJIT_DIR = vendor/LuaJIT
LUAJIT_SRC = $(LUAJIT_DIR)/src
LUAJIT_A   = $(LUAJIT_SRC)/libluajit.a
LUAJIT_BIN = LUA_PATH="$(LUAJIT_SRC)/?.lua" $(LUAJIT_SRC)/luajit
GEN_DIR    = gen

# Source locations
CHI          ?= chi
CHI_HOME     ?= $(HOME)/apps/chi
CHICC_LUA    = ../chicc.lua
RUNTIME_DIR  = ../runtime
UTF8_LUA     = $(RUNTIME_DIR)/utf8.lua
CHISTR_LUA   = $(RUNTIME_DIR)/chistr.lua
RUNTIME_LUA  = $(RUNTIME_DIR)/chi_runtime.lua
STDLIB_CHIM  = $(CHI_HOME)/lib/std.chim

# Generated bytecode headers
GEN_HEADERS = \
	$(GEN_DIR)/utf8_bc.h \
	$(GEN_DIR)/chistr_bc.h \
	$(GEN_DIR)/chi_runtime_bc.h \
	$(GEN_DIR)/std_chim_bc.h \
	$(GEN_DIR)/chicc_bc.h \
	$(GEN_DIR)/chi_build_bc.h

# Link flags
LIBS = -lm -ldl -lpthread
INCLUDES = -I$(LUAJIT_SRC)

.PHONY: all clean distclean install luajit bytecode

all: chi

# ---- LuaJIT from source ----

$(LUAJIT_DIR):
	@echo "=== Downloading LuaJIT 2.1 ==="
	mkdir -p vendor
	git clone --depth 1 --branch v2.1 https://github.com/LuaJIT/LuaJIT.git $(LUAJIT_DIR)

UNAME_S := $(shell uname -s)
ifeq ($(UNAME_S),Darwin)
  export MACOSX_DEPLOYMENT_TARGET ?= $(shell sw_vers -productVersion | cut -d. -f1-2)
endif

$(LUAJIT_A): | $(LUAJIT_DIR)
	@echo "=== Building LuaJIT (static) ==="
	$(MAKE) -C $(LUAJIT_DIR) BUILDMODE=static

luajit: $(LUAJIT_A)
	@echo "LuaJIT built: $(LUAJIT_A)"
	@ls -lh $(LUAJIT_A)
	@$(LUAJIT_BIN) -v

# ---- Bytecode generation ----

# Build chicc.lua from source if it doesn't exist
$(CHICC_LUA):
	cd .. && $(CHI) compile.chi

$(GEN_DIR):
	mkdir -p $(GEN_DIR)

$(GEN_DIR)/utf8_bc.h: $(UTF8_LUA) | $(GEN_DIR) $(LUAJIT_A)
	$(LUAJIT_BIN) -b -n utf8 $< $@

$(GEN_DIR)/chistr_bc.h: $(CHISTR_LUA) | $(GEN_DIR) $(LUAJIT_A)
	$(LUAJIT_BIN) -b -n chistr $< $@

$(GEN_DIR)/chi_runtime_bc.h: $(RUNTIME_LUA) | $(GEN_DIR) $(LUAJIT_A)
	$(LUAJIT_BIN) -b -n chi_runtime $< $@

$(GEN_DIR)/std_chim_bc.h: $(STDLIB_CHIM) | $(GEN_DIR) $(LUAJIT_A)
	$(LUAJIT_BIN) -b -n std_chim $< $@

$(GEN_DIR)/chicc_bc.h: $(CHICC_LUA) | $(GEN_DIR) $(LUAJIT_A)
	$(LUAJIT_BIN) -b -n chicc $< $@

$(GEN_DIR)/chi_build_bc.h: chi_build.lua | $(GEN_DIR) $(LUAJIT_A)
	$(LUAJIT_BIN) -b -n chi_build $< $@

bytecode: $(GEN_HEADERS)
	@echo "=== Generated bytecode headers ==="
	@ls -lh $(GEN_DIR)/*.h

# ---- Build chi binary ----

chi: chi_main.c $(GEN_HEADERS) $(LUAJIT_A)
	@echo "=== Compiling chi binary ==="
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $< $(LUAJIT_A) $(LIBS)
	@echo "Built: chi ($$(stat -c%s chi) bytes, $$(du -h chi | cut -f1))"

# ---- Install ----

install: chi
	@echo "=== Installing chi ==="
	mkdir -p $(CHI_HOME)/bin
	cp chi $(CHI_HOME)/bin/chi
	@echo "Installed to $(CHI_HOME)/bin/chi"
	@echo "Make sure $(CHI_HOME)/bin is in your PATH"

# ---- Clean ----

clean:
	rm -rf $(GEN_DIR) chi

distclean: clean
	rm -rf vendor
