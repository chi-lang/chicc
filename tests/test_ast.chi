import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/source { newSection }
import chicc/types { tInt, tString }
import chicc/ast { localTarget, packageTarget, atomExpr, blockExpr, fnCallExpr, variableAccessExpr, breakExpr, continueExpr, returnExpr, infixOpExpr, ifElseExpr }

test("localTarget") {
    val t = localTarget("x")
    assertEqual(t.tag, "local")
    assertEqual(t.name, "x")
    assertEqual(t.moduleName, "")
    assertEqual(t.packageName, "")
}

test("packageTarget") {
    val t = packageTarget("std", "lang", "println")
    assertEqual(t.tag, "package")
    assertEqual(t.name, "println")
    assertEqual(t.moduleName, "std")
    assertEqual(t.packageName, "lang")
}

test("atomExpr") {
    val sec = newSection(1, 1, 1, 5)
    val e = atomExpr("42", tInt, sec)
    assertEqual(e.exprKind(), "atom")
    assertEqual(e.exprAtomValue(), "42")
}

test("blockExpr") {
    val a1 = atomExpr("1", tInt, unit)
    val a2 = atomExpr("2", tInt, unit)
    val b = blockExpr([a1, a2], unit)
    assertEqual(b.exprKind(), "block")
}

test("fnCallExpr") {
    val func = variableAccessExpr(localTarget("foo"), unit)
    val arg = atomExpr("1", tInt, unit)
    val call = fnCallExpr(func, [arg], unit)
    assertEqual(call.exprKind(), "fn_call")
}

test("exprChildren - atom") {
    val e = atomExpr("42", tInt, unit)
    val children = e.exprChildren()
    assertEqual(children.size(), 0)
}

test("exprChildren - block") {
    val a1 = atomExpr("1", tInt, unit)
    val a2 = atomExpr("2", tInt, unit)
    val b = blockExpr([a1, a2], unit)
    val children = b.exprChildren()
    assertEqual(children.size(), 2)
}

test("exprChildren - fnCall") {
    val func = variableAccessExpr(localTarget("foo"), unit)
    val arg1 = atomExpr("1", tInt, unit)
    val arg2 = atomExpr("2", tInt, unit)
    val call = fnCallExpr(func, [arg1, arg2], unit)
    val children = call.exprChildren()
    assertEqual(children.size(), 3)
}

test("isTerminator - break") {
    assertTrue(isTerminator(breakExpr(unit)))
}

test("isTerminator - continue") {
    assertTrue(isTerminator(continueExpr(unit)))
}

test("isTerminator - return") {
    val rv = atomExpr("0", tInt, unit)
    assertTrue(isTerminator(returnExpr(rv, unit)))
}

test("isTerminator - atom") {
    assertFalse(isTerminator(atomExpr("42", tInt, unit)))
}

summary()
