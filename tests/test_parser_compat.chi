import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/parse_ast { PackageDefinition }
import std/io.file { readString }
import std/lang { luaExpr, embedLua }
import std/lang.array { size }

// Helper: parse a golden file and return the ParseProgram
// Uses pcall internally so parse failures don't crash the whole test suite
fn parseGoldenFile(path: string): any {
    val source = readString(path)
    val tokens = tokenize(source)
    val p = newParser(tokens, source)
    parseProgram(p)
}

// Helper: attempt to parse and return whether it succeeded
// Returns { ok: bool, result: any, error: string }
fn tryParseGolden(path: string): { ok: bool, result: any, errMsg: string } {
    embedLua("local source = readString(path)")
    embedLua("local ok2, tokens = pcall(tokenize, source)")
    embedLua("if not ok2 then __chi_parse_ok = false; __chi_parse_err = tostring(tokens); __chi_parse_result = nil; return end")
    embedLua("local p = newParser(tokens, source)")
    embedLua("local ok3, prog = pcall(parseProgram, p)")
    embedLua("__chi_parse_ok = ok3")
    embedLua("__chi_parse_err = ok3 and '' or tostring(prog)")
    embedLua("__chi_parse_result = ok3 and prog or nil")
    val ok: bool = luaExpr("__chi_parse_ok")
    val errMsg: string = luaExpr("__chi_parse_err") as string
    val result: any = luaExpr("__chi_parse_result")
    { ok: ok, result: result, errMsg: errMsg }
}

// ===== Control Flow =====

test("parse golden: control_flow/break") {
    val r = tryParseGolden("golden/control_flow/break.chi")
    assertTrue(r.ok)
    val prog = r.result
    assertTrue(prog.code.size() > 0)
    assertTrue(prog.packageDefinition is unit)
}

test("parse golden: control_flow/if_else") {
    val r = tryParseGolden("golden/control_flow/if_else.chi")
    assertTrue(r.ok)
    val prog = r.result
    assertTrue(prog.code.size() > 0)
}

