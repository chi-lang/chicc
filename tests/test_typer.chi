    icDefineLocalSymbol("arr", elemType)
    val constraints = newConstraints()
    val variable = variableAccessExpr(localTarget("arr"), testSection)
    val index = atomExpr("1", tInt, testSection)
    val expr = indexOpExpr(variable, index, testSection)
    val result = typeTerm(expr, 0, constraints)
    // Result should be a fresh variable linked to element type via constraint
    val resultTag: string = luaExpr("result.tag")
    assertEqual(resultTag, "var")
    val cCount: int = luaExpr("#constraints")
    assertTrue(cCount >= 2)
}

