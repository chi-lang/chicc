// --- typeTerm: create_record ---

test("typeTerm: create_record builds record type") {
    initTestCtx()
    val constraints = newConstraints()
    val val1 = atomExpr("42", tInt, testSection)
    val val2 = atomExpr("hello", tString, testSection)
    val fields: any = luaExpr("{}")
    val f1 = newExprField("x", val1)
    val f2 = newExprField("y", val2)
    embedLua("table.insert(fields, f1)")
    embedLua("table.insert(fields, f2)")
    val expr = createRecordExpr(fields, testSection)
    val result = typeTerm(expr, 0, constraints)
    val resultTag: string = luaExpr("result.tag")
    assertEqual(resultTag, "record")
    val resultFields: any = luaExpr("result.fields")
    val fCount: int = luaExpr("#resultFields")
    assertEqual(fCount, 2)
}

