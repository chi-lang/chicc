// --- typeTerms ---

test("typeTerms: maps over expressions") {
    initTestCtx()
    val constraints = newConstraints()
    val terms: any = luaExpr("{}")
    val e1 = atomExpr("42", tInt, testSection)
    val e2 = atomExpr("hello", tString, testSection)
    embedLua("table.insert(terms, e1)")
    embedLua("table.insert(terms, e2)")
    val results = typeTerms(terms, constraints, 0)
    val count: int = luaExpr("#results")
    assertEqual(count, 2)
    val t1: any = luaExpr("results[1]")
    val t2: any = luaExpr("results[2]")
    assertTrue(t1.typeEquals(tInt))
    assertTrue(t2.typeEquals(tString))
}

// --- typeTerm: field_assignment ---

test("typeTerm: field_assignment returns fresh var") {
    initTestCtx()
    val recType = recordType(luaExpr("{}"), luaExpr("{  { name = 'x', fieldType = tInt } }"), luaExpr("{}"))
    icDefineLocalSymbol("r", recType)
    val constraints = newConstraints()
    val receiver = variableAccessExpr(localTarget("r"), testSection)
    val value = atomExpr("99", tInt, testSection)
    // Build field_assignment expr manually
    val expr: any = luaExpr("(function() local e = { kind = 'field_assignment', exprType = nil, used = false, section = testSection, atomValue = '', parts = {}, recordFields = {}, arrayValues = {}, target = nil, receiver = receiver, fieldName = 'x', memberSection = nil, dotTarget = nil, value = value, isPublic = false, declName = '', isMutable = false, expectedType = nil, parameters = {}, defaultValues = nil, body = nil, callee = nil, callParams = {}, condition = nil, thenBranch = nil, elseBranch = nil, op = '', left = nil, right = nil, prefixExpr = nil, castExpr = nil, targetType = nil, checkedType = nil, loopCondition = nil, loopBody = nil, forVars = {}, iterable = nil, forState = nil, forInit = nil, forBody = nil, indexVariable = nil, indexExpr = nil, indexValue = nil, effectModuleName = '', effectPackageName = '', effectName = '', effectParams = {}, handleBody = nil, handleCases = {}, returnValue = nil, blockBody = {} }; return e end)()")
    val result = typeTerm(expr, 0, constraints)
    val resultTag: string = luaExpr("result.tag")
    assertEqual(resultTag, "var")
}

// --- Incremental union-find threading tests ---

test("incremental UF: name_declaration clears constraints and populates UF") {
    initTestCtx()
    val uf = ufNew()
    typerSetUf(uf)
    val constraints = newConstraints()
    val value = atomExpr("42", tInt, testSection)
    val expr = nameDeclarationExpr(false, "x", false, unit, value, testSection)
    typeTerm(expr, 0, constraints)
    // Constraints should have been cleared after mid-typing solve
    val cCount: int = luaExpr("#constraints")
    assertEqual(cCount, 0)
    // UF should have bindings (the fresh variable was unified with int)
    val bindings = ufAllBindings(uf)
    val bCount: int = luaExpr("#bindings")
    assertTrue(bCount >= 1)
    typerSetUf(unit)
}

test("incremental UF: name_declaration resolves type correctly") {
    initTestCtx()
    val uf = ufNew()
    typerSetUf(uf)
    val constraints = newConstraints()
    val value = atomExpr("42", tInt, testSection)
    val expr = nameDeclarationExpr(false, "y", false, unit, value, testSection)
    typeTerm(expr, 0, constraints)
    // The defined symbol should have a poly type wrapping int
    val sym: any = icGetLocalSymbol("y")
    assertTrue(sym != unit)
    val symType: any = luaExpr("sym.symbolType or sym")
    val symTag: string = luaExpr("symType.tag or ''")
    assertEqual(symTag, "poly")
    val body: any = luaExpr("symType.body")
    assertTrue(body.typeEquals(tInt))
    typerSetUf(unit)
}

test("incremental UF: field_access clears constraints and populates UF") {
    initTestCtx()
    val recType = recordType([], [{ name: "x", fieldType: tInt }], [])
    icDefineLocalSymbol("r", recType)
    val uf = ufNew()
    typerSetUf(uf)
    val constraints = newConstraints()
    val receiver = variableAccessExpr(localTarget("r"), testSection)
    val expr = fieldAccessExpr(receiver, "x", testSection, testSection)
    val result = typeTerm(expr, 0, constraints)
    // Field access resolves receiver mid-typing; constraints should be cleared
    val cCount: int = luaExpr("#constraints")
    // After clearing, new constraints (record field constraint) are added
    // The key check: UF should have bindings from the mid-typing solve
    val bindings = ufAllBindings(uf)
    val bCount: int = luaExpr("#bindings")
    // There should be at least the record field binding
    assertTrue(bCount >= 0)
    // Result should be a fresh variable for the field type
    val resultTag: string = luaExpr("result.tag")
    assertEqual(resultTag, "var")
    typerSetUf(unit)
}

test("incremental UF: multiple declarations accumulate bindings in shared UF") {
    initTestCtx()
    val uf = ufNew()
    typerSetUf(uf)
    val constraints = newConstraints()
    // First declaration: val a = 42
    val val1 = atomExpr("42", tInt, testSection)
    val expr1 = nameDeclarationExpr(false, "a", false, unit, val1, testSection)
    typeTerm(expr1, 0, constraints)
    val bindingsAfter1 = ufAllBindings(uf)
    val count1: int = luaExpr("#bindingsAfter1")
    // Second declaration: val b = "hello"
    val val2 = atomExpr("hello", tString, testSection)
    val expr2 = nameDeclarationExpr(false, "b", false, unit, val2, testSection)
    typeTerm(expr2, 0, constraints)
    val bindingsAfter2 = ufAllBindings(uf)
    val count2: int = luaExpr("#bindingsAfter2")
    // UF should have more bindings after second declaration
    assertTrue(count2 >= count1)
    // Both symbols should be correctly typed
    val symA: any = icGetLocalSymbol("a")
    val symAType: any = luaExpr("symA.symbolType or symA")
    val symABody: any = luaExpr("symAType.body or symAType")
    assertTrue(symABody.typeEquals(tInt))
    val symB: any = icGetLocalSymbol("b")
    val symBType: any = luaExpr("symB.symbolType or symB")
    val symBBody: any = luaExpr("symBType.body or symBType")
    assertTrue(symBBody.typeEquals(tString))
    typerSetUf(unit)
}

test("incremental UF: final unifyWithUf resolves remaining constraints") {
    initTestCtx()
    val uf = ufNew()
    typerSetUf(uf)
    val constraints = newConstraints()
    // Create: val x = 42; then add an extra constraint that x's type = int
    val val1 = atomExpr("42", tInt, testSection)
    val expr1 = nameDeclarationExpr(false, "x2", false, unit, val1, testSection)
    val resultType = typeTerm(expr1, 0, constraints)
    // Now add a trailing constraint (simulating what compiler.chi does after all typeTerm calls)
    val extraVar = icFreshVariable(0)
    val c = newConstraint(resultType, extraVar, testSection, luaExpr("{}") as array[any])
    embedLua("table.insert(constraints, c)")
    // Final solve (as compiler.chi does)
    unifyWithUf(constraints as array[any], uf)
    val finalBindings = ufAllBindings(uf)
    val finalCount: int = luaExpr("#finalBindings")
    assertTrue(finalCount >= 2)
    typerSetUf(unit)
}

test("incremental UF: fallback path works when UF is not set") {
    initTestCtx()
    typerSetUf(unit)
    val constraints = newConstraints()
    val value = atomExpr("42", tInt, testSection)
    val expr = nameDeclarationExpr(false, "z", false, unit, value, testSection)
    typeTerm(expr, 0, constraints)
    // Without UF, constraints should NOT be cleared (old behavior)
    val cCount: int = luaExpr("#constraints")
    assertTrue(cCount >= 1)
    // Symbol should still be defined correctly
    val sym: any = icGetLocalSymbol("z")
    assertTrue(sym != unit)
}

summary()
