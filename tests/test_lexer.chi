import chicc/test_util { test, assertEqual, assertTrue, summary }
import chicc/lexer { newLexer, lexPeek, lexPeekAt, lexAdvance, substringFrom }

test("newLexer initial state") {
    val lex = newLexer("hello")
    assertEqual(lex.pos, 1)
    assertEqual(lex.line, 1)
    assertEqual(lex.col, 1)
    assertEqual(lex.length, 5)
}

test("newLexer empty source") {
    val lex = newLexer("")
    assertEqual(lex.pos, 1)
    assertEqual(lex.line, 1)
    assertEqual(lex.col, 1)
    assertEqual(lex.length, 0)
}

test("lexPeek returns first char code") {
    val lex = newLexer("ABC")
    assertEqual(lexPeek(lex), 65)
}

test("lexPeek at EOF returns 0") {
    val lex = newLexer("")
    assertEqual(lexPeek(lex), 0)
}

test("lexPeekAt with offset 0 same as lexPeek") {
    val lex = newLexer("ABC")
    assertEqual(lexPeekAt(lex, 0), lexPeek(lex))
}

test("lexPeekAt with positive offset") {
    val lex = newLexer("ABC")
    assertEqual(lexPeekAt(lex, 0), 65)
    assertEqual(lexPeekAt(lex, 1), 66)
    assertEqual(lexPeekAt(lex, 2), 67)
}

test("lexPeekAt past end returns 0") {
    val lex = newLexer("AB")
    assertEqual(lexPeekAt(lex, 5), 0)
}

test("lexAdvance moves position and column") {
    val lex = newLexer("ABC")
    assertEqual(lex.pos, 1)
    assertEqual(lex.col, 1)
    lexAdvance(lex)
    assertEqual(lex.pos, 2)
    assertEqual(lex.col, 2)
    assertEqual(lex.line, 1)
    lexAdvance(lex)
    assertEqual(lex.pos, 3)
    assertEqual(lex.col, 3)
}

test("lexAdvance handles newline") {
    val lex = newLexer("a\nb")
    lexAdvance(lex)
    assertEqual(lex.pos, 2)
    assertEqual(lex.line, 1)
    assertEqual(lex.col, 2)
    lexAdvance(lex)
    assertEqual(lex.pos, 3)
    assertEqual(lex.line, 2)
    assertEqual(lex.col, 1)
    lexAdvance(lex)
    assertEqual(lex.pos, 4)
    assertEqual(lex.line, 2)
    assertEqual(lex.col, 2)
}

test("lexAdvance at EOF is safe") {
    val lex = newLexer("a")
    lexAdvance(lex)
    assertEqual(lex.pos, 2)
    lexAdvance(lex)
    assertEqual(lex.pos, 2)
}

test("substringFrom extracts text") {
    val lex = newLexer("hello world")
    assertEqual(substringFrom(lex, 1, 5), "hello")
    assertEqual(substringFrom(lex, 7, 11), "world")
    assertEqual(substringFrom(lex, 1, 11), "hello world")
}

test("substringFrom single char") {
    val lex = newLexer("ABC")
    assertEqual(substringFrom(lex, 2, 2), "B")
}

test("lexPeek after lexAdvance") {
    val lex = newLexer("XY")
    assertEqual(lexPeek(lex), 88)
    lexAdvance(lex)
    assertEqual(lexPeek(lex), 89)
    lexAdvance(lex)
    assertEqual(lexPeek(lex), 0)
}

test("multiple newlines") {
    val lex = newLexer("\n\n\n")
    assertEqual(lex.line, 1)
    lexAdvance(lex)
    assertEqual(lex.line, 2)
    assertEqual(lex.col, 1)
    lexAdvance(lex)
    assertEqual(lex.line, 3)
    assertEqual(lex.col, 1)
    lexAdvance(lex)
    assertEqual(lex.line, 4)
    assertEqual(lex.col, 1)
}

summary()
