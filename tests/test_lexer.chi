import user/test_util { test, assertEqual, assertTrue, summary }
import user/lexer { newLexer, peek, peekAt, advance, substringFrom }

test("newLexer initial state") {
    val lex = newLexer("hello")
    assertEqual(lex.pos, 1)
    assertEqual(lex.line, 1)
    assertEqual(lex.col, 1)
    assertEqual(lex.length, 5)
}

test("newLexer empty source") {
    val lex = newLexer("")
    assertEqual(lex.pos, 1)
    assertEqual(lex.line, 1)
    assertEqual(lex.col, 1)
    assertEqual(lex.length, 0)
}

test("peek returns first char code") {
    val lex = newLexer("ABC")
    assertEqual(peek(lex), 65)
}

test("peek at EOF returns 0") {
    val lex = newLexer("")
    assertEqual(peek(lex), 0)
}

test("peekAt with offset 0 same as peek") {
    val lex = newLexer("ABC")
    assertEqual(peekAt(lex, 0), peek(lex))
}

test("peekAt with positive offset") {
    val lex = newLexer("ABC")
    assertEqual(peekAt(lex, 0), 65)
    assertEqual(peekAt(lex, 1), 66)
    assertEqual(peekAt(lex, 2), 67)
}

test("peekAt past end returns 0") {
    val lex = newLexer("AB")
    assertEqual(peekAt(lex, 5), 0)
}

test("advance moves position and column") {
    val lex = newLexer("ABC")
    assertEqual(lex.pos, 1)
    assertEqual(lex.col, 1)
    advance(lex)
    assertEqual(lex.pos, 2)
    assertEqual(lex.col, 2)
    assertEqual(lex.line, 1)
    advance(lex)
    assertEqual(lex.pos, 3)
    assertEqual(lex.col, 3)
}

test("advance handles newline") {
    val lex = newLexer("a\nb")
    advance(lex)
    assertEqual(lex.pos, 2)
    assertEqual(lex.line, 1)
    assertEqual(lex.col, 2)
    advance(lex)
    assertEqual(lex.pos, 3)
    assertEqual(lex.line, 2)
    assertEqual(lex.col, 1)
    advance(lex)
    assertEqual(lex.pos, 4)
    assertEqual(lex.line, 2)
    assertEqual(lex.col, 2)
}

test("advance at EOF is safe") {
    val lex = newLexer("a")
    advance(lex)
    assertEqual(lex.pos, 2)
    advance(lex)
    assertEqual(lex.pos, 2)
}

test("substringFrom extracts text") {
    val lex = newLexer("hello world")
    assertEqual(substringFrom(lex, 1, 5), "hello")
    assertEqual(substringFrom(lex, 7, 11), "world")
    assertEqual(substringFrom(lex, 1, 11), "hello world")
}

test("substringFrom single char") {
    val lex = newLexer("ABC")
    assertEqual(substringFrom(lex, 2, 2), "B")
}

test("peek after advance") {
    val lex = newLexer("XY")
    assertEqual(peek(lex), 88)
    advance(lex)
    assertEqual(peek(lex), 89)
    advance(lex)
    assertEqual(peek(lex), 0)
}

test("multiple newlines") {
    val lex = newLexer("\n\n\n")
    assertEqual(lex.line, 1)
    advance(lex)
    assertEqual(lex.line, 2)
    assertEqual(lex.col, 1)
    advance(lex)
    assertEqual(lex.line, 3)
    assertEqual(lex.col, 1)
    advance(lex)
    assertEqual(lex.line, 4)
    assertEqual(lex.col, 1)
}

summary()
