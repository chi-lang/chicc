import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/token { Token, newToken, TK_INTERP_START, TK_INTERP_TEXT, TK_INTERP_EXPR_START, TK_INTERP_EXPR_END, TK_INTERP_END, TK_ID, TK_INT, TK_PLUS, TK_STRING, TK_EOF }
import chicc/parser { newParser, parseExpression }
import chicc/parse_ast { ParseAst }

fn tk(kind: int, value: string): Token { newToken(kind, value, unit) }
fn eof(): Token { newToken(TK_EOF, "", unit) }

// --- Interpolated String Parsing ---

test("parse interpolated string with text only") {
    // "hello world" as interpolated string (just text, no expressions)
    val tokens = [
        tk(TK_INTERP_START, ""),
        tk(TK_INTERP_TEXT, "hello world"),
        tk(TK_INTERP_END, ""),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.tag, "ParseInterpolatedString")
    val parts = result.parts
    assertEqual(parts.size(), 1)
    assertEqual((parts[1] as ParseAst).tag, "StringText")
    assertEqual((parts[1] as ParseAst).stringValue, "hello world")
}

test("parse interpolated string with single variable") {
    // "hello $name"
    val tokens = [
        tk(TK_INTERP_START, ""),
        tk(TK_INTERP_TEXT, "hello "),
        tk(TK_INTERP_EXPR_START, ""),
        tk(TK_ID, "name"),
        tk(TK_INTERP_EXPR_END, ""),
        tk(TK_INTERP_END, ""),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.tag, "ParseInterpolatedString")
    val parts = result.parts
    assertEqual(parts.size(), 2)
    assertEqual((parts[1] as ParseAst).tag, "StringText")
    assertEqual((parts[1] as ParseAst).stringValue, "hello ")
    assertEqual((parts[2] as ParseAst).tag, "ParseInterpolation")
    val expr = (parts[2] as ParseAst).interpValue as ParseAst
    assertEqual(expr.tag, "ParseVariableRead")
    assertEqual(expr.variableName, "name")
}

test("parse interpolated string with expression") {
    // "${1+2}"
    val tokens = [
        tk(TK_INTERP_START, ""),
        tk(TK_INTERP_EXPR_START, ""),
        tk(TK_INT, "1"),
        tk(TK_PLUS, "+"),
        tk(TK_INT, "2"),
        tk(TK_INTERP_EXPR_END, ""),
        tk(TK_INTERP_END, ""),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.tag, "ParseInterpolatedString")
    val parts = result.parts
    assertEqual(parts.size(), 1)
    assertEqual((parts[1] as ParseAst).tag, "ParseInterpolation")
    val expr = (parts[1] as ParseAst).interpValue as ParseAst
    assertEqual(expr.tag, "ParseBinaryOp")
    assertEqual(expr.op, "+")
    assertEqual((expr.left as ParseAst).longValue, 1)
    assertEqual((expr.right as ParseAst).longValue, 2)
}

test("parse interpolated string with text and expression") {
    // "hello $name, ${1+2}!"
    val tokens = [
        tk(TK_INTERP_START, ""),
        tk(TK_INTERP_TEXT, "hello "),
        tk(TK_INTERP_EXPR_START, ""),
        tk(TK_ID, "name"),
        tk(TK_INTERP_EXPR_END, ""),
        tk(TK_INTERP_TEXT, ", "),
        tk(TK_INTERP_EXPR_START, ""),
        tk(TK_INT, "1"),
        tk(TK_PLUS, "+"),
        tk(TK_INT, "2"),
        tk(TK_INTERP_EXPR_END, ""),
        tk(TK_INTERP_TEXT, "!"),
        tk(TK_INTERP_END, ""),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.tag, "ParseInterpolatedString")
    val parts = result.parts
    assertEqual(parts.size(), 5)
    // "hello "
    assertEqual((parts[1] as ParseAst).tag, "StringText")
    assertEqual((parts[1] as ParseAst).stringValue, "hello ")
    // $name
    assertEqual((parts[2] as ParseAst).tag, "ParseInterpolation")
    val nameExpr = (parts[2] as ParseAst).interpValue as ParseAst
    assertEqual(nameExpr.tag, "ParseVariableRead")
    assertEqual(nameExpr.variableName, "name")
    // ", "
    assertEqual((parts[3] as ParseAst).tag, "StringText")
    assertEqual((parts[3] as ParseAst).stringValue, ", ")
    // ${1+2}
    assertEqual((parts[4] as ParseAst).tag, "ParseInterpolation")
    val addExpr = (parts[4] as ParseAst).interpValue as ParseAst
    assertEqual(addExpr.tag, "ParseBinaryOp")
    assertEqual(addExpr.op, "+")
    // "!"
    assertEqual((parts[5] as ParseAst).tag, "StringText")
    assertEqual((parts[5] as ParseAst).stringValue, "!")
}

test("parse empty interpolated string") {
    // "" as interpolated string (no parts)
    val tokens = [
        tk(TK_INTERP_START, ""),
        tk(TK_INTERP_END, ""),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.tag, "ParseInterpolatedString")
    val parts = result.parts
    assertEqual(parts.size(), 0)
}

test("parse interpolated string with multiple adjacent expressions") {
    // "${a}${b}"
    val tokens = [
        tk(TK_INTERP_START, ""),
        tk(TK_INTERP_EXPR_START, ""),
        tk(TK_ID, "a"),
        tk(TK_INTERP_EXPR_END, ""),
        tk(TK_INTERP_EXPR_START, ""),
        tk(TK_ID, "b"),
        tk(TK_INTERP_EXPR_END, ""),
        tk(TK_INTERP_END, ""),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.tag, "ParseInterpolatedString")
    val parts = result.parts
    assertEqual(parts.size(), 2)
    assertEqual((parts[1] as ParseAst).tag, "ParseInterpolation")
    assertEqual(((parts[1] as ParseAst).interpValue as ParseAst).variableName, "a")
    assertEqual((parts[2] as ParseAst).tag, "ParseInterpolation")
    assertEqual(((parts[2] as ParseAst).interpValue as ParseAst).variableName, "b")
}

summary()
