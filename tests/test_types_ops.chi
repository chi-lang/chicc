import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/types { Type, TypeId, RecordField, newTypeId, typeIdToString, anyTypeId, unitTypeId, boolTypeId, intTypeId, floatTypeId, stringTypeId, optionTypeId, arrayTypeId, tAny, tUnit, tBool, tInt, tFloat, tString, primitiveType, functionType, recordType, sumType, arrayType, variableType, recursiveType, polyType, typeChildren, mapType, sumCreate }
import std/lang { luaExpr, embedLua }

// --- typeEquals ---

test("typeEquals: same primitives") {
    assertTrue(tInt.typeEquals(tInt))
    assertTrue(tString.typeEquals(tString))
    assertTrue(tBool.typeEquals(tBool))
    assertTrue(tUnit.typeEquals(tUnit))
}

test("typeEquals: different primitives") {
    assertFalse(tInt.typeEquals(tString))
    assertFalse(tBool.typeEquals(tFloat))
}

test("typeEquals: primitive with intersecting ids") {
    val alias = primitiveType([intTypeId, newTypeId("mymod", "mypkg", "MyInt")])
    assertTrue(tInt.typeEquals(alias))
    assertTrue(alias.typeEquals(tInt))
}

test("typeEquals: primitive with no intersection") {
    val custom1 = primitiveType([newTypeId("a", "b", "X")])
    val custom2 = primitiveType([newTypeId("c", "d", "Y")])
    assertFalse(custom1.typeEquals(custom2))
}

test("typeEquals: same function types") {
    val f1 = functionType([tInt, tString], [], 0)
    val f2 = functionType([tInt, tString], [], 0)
    assertTrue(f1.typeEquals(f2))
}

test("typeEquals: different function types (different params)") {
    val f1 = functionType([tInt, tString], [], 0)
    val f2 = functionType([tBool, tString], [], 0)
    assertFalse(f1.typeEquals(f2))
}

test("typeEquals: different function types (different length)") {
    val f1 = functionType([tInt, tString], [], 0)
    val f2 = functionType([tInt, tString, tBool], [], 0)
    assertFalse(f1.typeEquals(f2))
}

test("typeEquals: same record types") {
    val r1 = recordType([], [{ name: "x", fieldType: tInt }, { name: "y", fieldType: tString }], [])
    val r2 = recordType([], [{ name: "x", fieldType: tInt }, { name: "y", fieldType: tString }], [])
    assertTrue(r1.typeEquals(r2))
}

test("typeEquals: different record types (different field name)") {
    val r1 = recordType([], [{ name: "x", fieldType: tInt }], [])
    val r2 = recordType([], [{ name: "y", fieldType: tInt }], [])
    assertFalse(r1.typeEquals(r2))
}

test("typeEquals: different record types (different field type)") {
    val r1 = recordType([], [{ name: "x", fieldType: tInt }], [])
    val r2 = recordType([], [{ name: "x", fieldType: tString }], [])
    assertFalse(r1.typeEquals(r2))
}

test("typeEquals: different record types (different length)") {
    val r1 = recordType([], [{ name: "x", fieldType: tInt }], [])
    val r2 = recordType([], [{ name: "x", fieldType: tInt }, { name: "y", fieldType: tString }], [])
    assertFalse(r1.typeEquals(r2))
}

test("typeEquals: same sum types") {
    val s1 = sumType([], tInt, tString, [])
    val s2 = sumType([], tInt, tString, [])
    assertTrue(s1.typeEquals(s2))
}

test("typeEquals: different sum types") {
    val s1 = sumType([], tInt, tString, [])
    val s2 = sumType([], tInt, tBool, [])
    assertFalse(s1.typeEquals(s2))
}

test("typeEquals: same array types") {
    val a1 = arrayType(tInt, [])
    val a2 = arrayType(tInt, [])
    assertTrue(a1.typeEquals(a2))
}

test("typeEquals: different array types") {
    val a1 = arrayType(tInt, [])
    val a2 = arrayType(tString, [])
    assertFalse(a1.typeEquals(a2))
}

test("typeEquals: same variable types") {
    val v1 = variableType("T", 0)
    val v2 = variableType("T", 0)
    assertTrue(v1.typeEquals(v2))
}

test("typeEquals: different variable types (name)") {
    val v1 = variableType("T", 0)
    val v2 = variableType("U", 0)
    assertFalse(v1.typeEquals(v2))
}

test("typeEquals: different variable types (level)") {
    val v1 = variableType("T", 0)
    val v2 = variableType("T", 1)
    assertFalse(v1.typeEquals(v2))
}

test("typeEquals: same recursive types") {
    val v = variableType("X", 0)
    val inner = recordType([], [{ name: "a", fieldType: tInt }, { name: "next", fieldType: v }], [])
    val r1 = recursiveType(v, inner)
    val r2 = recursiveType(v, inner)
    assertTrue(r1.typeEquals(r2))
}

test("typeEquals: same poly types") {
    val v = variableType("T", 0)
    val body = functionType([v, v], [], 0)
    val p1 = polyType(1, body)
    val p2 = polyType(1, body)
    assertTrue(p1.typeEquals(p2))
}

test("typeEquals: different poly types (different level)") {
    val v = variableType("T", 0)
    val body = functionType([v, v], [], 0)
    val p1 = polyType(1, body)
    val p2 = polyType(2, body)
    assertFalse(p1.typeEquals(p2))
}

test("typeEquals: different tags") {
    assertFalse(tInt.typeEquals(variableType("T", 0)))
    assertFalse(typeEquals(functionType([tInt], [], 0), tString))
}

// --- typeChildren ---

test("typeChildren: primitive has no children") {
    val children = typeChildren(tInt)
    val count: int = luaExpr("#children")
    assertEqual(count, 0)
}

test("typeChildren: function returns types array") {
    val f = functionType([tInt, tString, tBool], [], 0)
    val children = typeChildren(f)
    val count: int = luaExpr("#children")
    assertEqual(count, 3)
    val c1: Type = luaExpr("children[1]")
    val c2: Type = luaExpr("children[2]")
    val c3: Type = luaExpr("children[3]")
    assertTrue(c1.typeEquals(tInt))
    assertTrue(c2.typeEquals(tString))
    assertTrue(c3.typeEquals(tBool))
}

test("typeChildren: record returns field types") {
    val r = recordType([], [{ name: "x", fieldType: tInt }, { name: "y", fieldType: tString }], [])
    val children = typeChildren(r)
    val count: int = luaExpr("#children")
    assertEqual(count, 2)
    val c1: Type = luaExpr("children[1]")
    val c2: Type = luaExpr("children[2]")
    assertTrue(c1.typeEquals(tInt))
    assertTrue(c2.typeEquals(tString))
}

test("typeChildren: sum returns lhs and rhs") {
    val s = sumType([], tInt, tString, [])
    val children = typeChildren(s)
    val count: int = luaExpr("#children")
    assertEqual(count, 2)
    val c1: Type = luaExpr("children[1]")
    val c2: Type = luaExpr("children[2]")
    assertTrue(c1.typeEquals(tInt))
    assertTrue(c2.typeEquals(tString))
}

test("typeChildren: array returns element type") {
    val a = arrayType(tInt, [])
    val children = typeChildren(a)
    val count: int = luaExpr("#children")
    assertEqual(count, 1)
    val c1: Type = luaExpr("children[1]")
    assertTrue(c1.typeEquals(tInt))
}

test("typeChildren: variable has no children") {
    val v = variableType("T", 0)
    val children = typeChildren(v)
    val count: int = luaExpr("#children")
    assertEqual(count, 0)
}

test("typeChildren: recursive returns innerType") {
    val v = variableType("X", 0)
    val inner = recordType([], [{ name: "a", fieldType: tInt }], [])
    val r = recursiveType(v, inner)
    val children = typeChildren(r)
    val count: int = luaExpr("#children")
    assertEqual(count, 1)
    val c1: Type = luaExpr("children[1]")
    assertTrue(c1.typeEquals(inner))
}

test("typeChildren: poly returns body") {
    val body = functionType([tInt, tString], [], 0)
    val p = polyType(1, body)
    val children = typeChildren(p)
    val count: int = luaExpr("#children")
    assertEqual(count, 1)
    val c1: Type = luaExpr("children[1]")
    assertTrue(c1.typeEquals(body))
}

// --- replaceVariable ---

test("replaceVariable: replace matching var") {
    val v = variableType("T", 0)
    val result = v.replaceVariable(v, tInt)
    assertTrue(result.typeEquals(tInt))
}

test("replaceVariable: keep non-matching var") {
    val v1 = variableType("T", 0)
    val v2 = variableType("U", 0)
    val result = v1.replaceVariable(v2, tInt)
    assertTrue(result.typeEquals(v1))
}

test("replaceVariable: primitive unchanged") {
    val v = variableType("T", 0)
    val result = tInt.replaceVariable(v, tString)
    assertTrue(result.typeEquals(tInt))
}

test("replaceVariable: in function type") {
    val v = variableType("T", 0)
    val f = functionType([v, tString], [], 0)
    val result = f.replaceVariable(v, tInt)
    val expected = functionType([tInt, tString], [], 0)
    assertTrue(result.typeEquals(expected))
}

test("replaceVariable: in record type") {
    val v = variableType("T", 0)
    val r = recordType([], [{ name: "x", fieldType: v }, { name: "y", fieldType: tString }], [])
    val result = r.replaceVariable(v, tInt)
    val expected = recordType([], [{ name: "x", fieldType: tInt }, { name: "y", fieldType: tString }], [])
    assertTrue(result.typeEquals(expected))
}

test("replaceVariable: in array type") {
    val v = variableType("T", 0)
    val a = arrayType(v, [])
    val result = a.replaceVariable(v, tInt)
    val expected = arrayType(tInt, [])
    assertTrue(result.typeEquals(expected))
}

test("replaceVariable: in recursive type") {
    val v = variableType("T", 0)
    val recVar = variableType("X", 0)
    val inner = recordType([], [{ name: "val", fieldType: v }], [])
    val rec = recursiveType(recVar, inner)
    val result = rec.replaceVariable(v, tInt)
    val expectedInner = recordType([], [{ name: "val", fieldType: tInt }], [])
    val expected = recursiveType(recVar, expectedInner)
    assertTrue(result.typeEquals(expected))
}

test("replaceVariable: in poly type") {
    val v = variableType("T", 0)
    val body = functionType([v, tString], [], 0)
    val p = polyType(1, body)
    val result = p.replaceVariable(v, tInt)
    val expectedBody = functionType([tInt, tString], [], 0)
    val expected = polyType(1, expectedBody)
    assertTrue(result.typeEquals(expected))
}

test("replaceVariable: deep nested") {
    val v = variableType("T", 0)
    val inner = functionType([v, v], [], 0)
    val outer = functionType([inner, v], [], 0)
    val result = outer.replaceVariable(v, tInt)
    val expectedInner = functionType([tInt, tInt], [], 0)
    val expected = functionType([expectedInner, tInt], [], 0)
    assertTrue(result.typeEquals(expected))
}

// --- mapType ---

test("mapType: single replacement") {
    val v = variableType("T", 0)
    val f = functionType([v, tString], [], 0)
    val replacements: array[any] = luaExpr("{}")
    val entry = { variable: v, replacement: tInt }
    embedLua("table.insert(replacements, entry)")
    val result = mapType(f, replacements)
    val expected = functionType([tInt, tString], [], 0)
    assertTrue(result.typeEquals(expected))
}

test("mapType: multiple replacements") {
    val v1 = variableType("T", 0)
    val v2 = variableType("U", 0)
    val f = functionType([v1, v2], [], 0)
    val replacements: array[any] = luaExpr("{}")
    val e1 = { variable: v1, replacement: tInt }
    val e2 = { variable: v2, replacement: tString }
    embedLua("table.insert(replacements, e1)")
    embedLua("table.insert(replacements, e2)")
    val result = mapType(f, replacements)
    val expected = functionType([tInt, tString], [], 0)
    assertTrue(result.typeEquals(expected))
}

test("mapType: empty replacements") {
    val f = functionType([tInt, tString], [], 0)
    val replacements: array[any] = luaExpr("{}")
    val result = mapType(f, replacements)
    assertTrue(result.typeEquals(f))
}

// --- occursIn ---

test("occursIn: variable occurs in itself") {
    val v = variableType("T", 0)
    assertTrue(v.occursIn(v))
}

test("occursIn: variable not in primitive") {
    val v = variableType("T", 0)
    assertFalse(v.occursIn(tInt))
}

test("occursIn: variable in function type") {
    val v = variableType("T", 0)
    val f = functionType([v, tString], [], 0)
    assertTrue(v.occursIn(f))
}

test("occursIn: variable not in function type") {
    val v = variableType("T", 0)
    val f = functionType([tInt, tString], [], 0)
    assertFalse(v.occursIn(f))
}

test("occursIn: variable in record type") {
    val v = variableType("T", 0)
    val r = recordType([], [{ name: "x", fieldType: v }], [])
    assertTrue(v.occursIn(r))
}

test("occursIn: variable in array type") {
    val v = variableType("T", 0)
    val a = arrayType(v, [])
    assertTrue(v.occursIn(a))
}

test("occursIn: variable in sum type") {
    val v = variableType("T", 0)
    val s = sumType([], v, tInt, [])
    assertTrue(v.occursIn(s))
}

test("occursIn: different variable not found") {
    val v1 = variableType("T", 0)
    val v2 = variableType("U", 0)
    val f = functionType([v2, tString], [], 0)
    assertFalse(v1.occursIn(f))
}

test("occursIn: deep nesting") {
    val v = variableType("T", 0)
    val inner = arrayType(v, [])
    val outer = functionType([inner, tString], [], 0)
    assertTrue(v.occursIn(outer))
}

// --- sumListTypes ---

test("sumListTypes: non-sum returns singleton") {
    val result = tInt.sumListTypes()
    val count: int = luaExpr("#result")
    assertEqual(count, 1)
    val item: Type = luaExpr("result[1]")
    assertTrue(item.typeEquals(tInt))
}

test("sumListTypes: simple sum") {
    val s = sumType([], tInt, tString, [])
    val result = s.sumListTypes()
    val count: int = luaExpr("#result")
    assertEqual(count, 2)
    val item1: Type = luaExpr("result[1]")
    val item2: Type = luaExpr("result[2]")
    assertTrue(item1.typeEquals(tInt))
    assertTrue(item2.typeEquals(tString))
}

test("sumListTypes: nested sum") {
    val inner = sumType([], tInt, tString, [])
    val outer = sumType([], inner, tBool, [])
    val result = outer.sumListTypes()
    val count: int = luaExpr("#result")
    assertEqual(count, 3)
    val item1: Type = luaExpr("result[1]")
    val item2: Type = luaExpr("result[2]")
    val item3: Type = luaExpr("result[3]")
    assertTrue(item1.typeEquals(tInt))
    assertTrue(item2.typeEquals(tString))
    assertTrue(item3.typeEquals(tBool))
}

// --- occursInExcludingSumBranches ---

test("occursInExcludingSumBranches: variable in sum as a branch only") {
    val v = variableType("T", 0)
    val s = sumType([], v, tInt, [])
    assertFalse(v.occursInExcludingSumBranches(s))
}

test("occursInExcludingSumBranches: variable in sum in a branch content") {
    val v = variableType("T", 0)
    val nested = functionType([v, tString], [], 0)
    val s = sumType([], nested, tInt, [])
    assertTrue(v.occursInExcludingSumBranches(s))
}

test("occursInExcludingSumBranches: variable matches directly") {
    val v = variableType("T", 0)
    assertTrue(v.occursInExcludingSumBranches(v))
}

test("occursInExcludingSumBranches: non-sum type delegates to occursIn") {
    val v = variableType("T", 0)
    val f = functionType([v, tString], [], 0)
    assertTrue(v.occursInExcludingSumBranches(f))
}

test("occursInExcludingSumBranches: non-sum without variable") {
    val v = variableType("T", 0)
    val f = functionType([tInt, tString], [], 0)
    assertFalse(v.occursInExcludingSumBranches(f))
}

// --- sumCreate ---

test("sumCreate: basic creation") {
    val result = sumCreate([], tInt, tString, [])
    assertTrue(result.isSum())
    val lhs: Type = luaExpr("result.lhs")
    val rhs: Type = luaExpr("result.rhs")
    assertTrue(lhs.typeEquals(tInt))
    assertTrue(rhs.typeEquals(tString))
}

test("sumCreate: auto-adds optionTypeId when unit present") {
    val result = sumCreate([], tInt, tUnit, [])
    val ids = result.typeIds()
    var found = false
    val count = ids.size()
    var i = 1
    while i <= count {
        if typeIdEquals(ids[i], optionTypeId) { found = true }
        i = i + 1
    }
    assertTrue(found)
}

test("sumCreate: does not duplicate optionTypeId") {
    val result = sumCreate([optionTypeId], tInt, tUnit, [])
    val ids = result.typeIds()
    var optCount = 0
    val count = ids.size()
    var i = 1
    while i <= count {
        if typeIdEquals(ids[i], optionTypeId) { optCount = optCount + 1 }
        i = i + 1
    }
    assertEqual(optCount, 1)
}

test("sumCreate: no optionTypeId when no unit") {
    val result = sumCreate([], tInt, tString, [])
    val ids = result.typeIds()
    var found = false
    val count = ids.size()
    var i = 1
    while i <= count {
        if typeIdEquals(ids[i], optionTypeId) { found = true }
        i = i + 1
    }
    assertFalse(found)
}

test("sumCreate: deduplicates types") {
    val result = sumCreate([], tInt, tInt, [])
    // When both sides are the same non-sum type, result should be just the type
    assertTrue(result.typeEquals(tInt))
}

test("sumCreate: flattens nested sums") {
    val inner = sumType([], tInt, tString, [])
    val result = sumCreate([], inner, tBool, [])
    val list = result.sumListTypes()
    val count: int = luaExpr("#list")
    assertEqual(count, 3)
}

// --- unfoldRecursive ---

test("unfoldRecursive: replaces variable with recursive type") {
    val v = variableType("X", 0)
    val inner = recordType([], [{ name: "val", fieldType: tInt }, { name: "next", fieldType: v }], [])
    val rec = recursiveType(v, inner)
    val unfolded = rec.unfoldRecursive()
    // The unfolded type should be a record where 'next' field is the recursive type itself
    assertTrue(unfolded.isRecord())
    val fields = unfolded.typeFields()
    val f2: RecordField = luaExpr("fields[2]")
    val f2Type: Type = luaExpr("f2.fieldType")
    assertTrue(f2Type.isRecursive())
}

// --- instantiate ---

test("instantiate: non-poly returns as-is") {
    val result = tInt.instantiate(5, { lvl: int -> variableType("fresh", lvl) })
    assertTrue(result.typeEquals(tInt))
}

test("instantiate: replaces variables above level") {
    val v = variableType("T", 2)
    val body = functionType([v, tString], [], 0)
    val p = polyType(1, body)
    var counter = 0
    val result = p.instantiate(5, { lvl: int ->
        counter = counter + 1
        variableType("fresh${counter}", lvl)
    })
    assertTrue(result.isFunction())
    // The variable T at level 2 is above startingLevel 1, so it should be replaced
    val types = result.typeTypes()
    val firstType: Type = luaExpr("types[1]")
    assertFalse(firstType.typeEquals(v))
    assertTrue(firstType.isVariable())
    assertEqual(firstType.typeLevel(), 5)
}

test("instantiate: keeps variables at or below level") {
    val v1 = variableType("T", 1)
    val v2 = variableType("U", 0)
    val body = functionType([v1, v2], [], 0)
    val p = polyType(1, body)
    var counter = 0
    val result = p.instantiate(5, { lvl: int ->
        counter = counter + 1
        variableType("fresh${counter}", lvl)
    })
    assertTrue(result.isFunction())
    val types = result.typeTypes()
    val firstType: Type = luaExpr("types[1]")
    val secondType: Type = luaExpr("types[2]")
    // v1 is at level 1 which equals startingLevel 1, so it should NOT be replaced
    assertTrue(firstType.typeEquals(v1))
    // v2 is at level 0 which is below startingLevel 1, so it should NOT be replaced
    assertTrue(secondType.typeEquals(v2))
}

test("instantiate: caches same variable") {
    val v = variableType("T", 2)
    val body = functionType([v, v], [], 0)
    val p = polyType(1, body)
    var counter = 0
    val result = p.instantiate(5, { lvl: int ->
        counter = counter + 1
        variableType("fresh${counter}", lvl)
    })
    assertTrue(result.isFunction())
    val types = result.typeTypes()
    val firstType: Type = luaExpr("types[1]")
    val secondType: Type = luaExpr("types[2]")
    // Both occurrences of T should map to the same fresh variable
    assertTrue(firstType.typeEquals(secondType))
    // counter should be 1, because only one fresh var was created
    assertEqual(counter, 1)
}

summary()
