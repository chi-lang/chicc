import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/source { newSection }
import chicc/parse_ast { ParseAst, TypeRef, typeParameterRef, typeNameRef, functionTypeRef, sumTypeRef, typeConstructorRef, recordTypeRef, newFormalArgument, newFormalField, newParseHandleCase, newParseWhenCase, newParseElseCase, newParseRecordField, newTypeRefField, newPackageDefinition, newParseImportEntry, newParseImport, parseUnitValue, parseLongValue, parseFloatValue, parseBoolValue, parseStringValue, parseStringText, parseInterpolation, parseInterpolatedString, parseLambda, parseFuncWithName, parseFnCall, parseVariableRead, parseAssignment, parseIndexOperator, parseIndexedAssignment, parseNameDeclaration, parseBlock, parseGroup, parseIfElse, parseWhile, parseFor, parseWhen, parseReturn, parseBreak, parseContinue, parseNot, parseBinaryOp, parseCast, parseIs, parseFieldAccess, parseFieldAssignment, parseEffectDefinition, parseHandle, parseWeave, parseWeavePlaceholder, parseCreateArray, parseCreateRecord }


test("TypeRef - TypeParameterRef") {
    val tr = typeParameterRef("T", unit)
    assertEqual(tr.tag, "TypeParameterRef")
    assertEqual(tr.name, "T")
}

test("TypeRef - TypeNameRef") {
    val tr = typeNameRef("std", "lang", "int", unit)
    assertEqual(tr.tag, "TypeNameRef")
    assertEqual(tr.moduleName, "std")
    assertEqual(tr.packageName, "lang")
    assertEqual(tr.name, "int")
}

test("TypeRef - SumTypeRef") {
    val left = typeNameRef("", "", "int", unit)
    val right = typeNameRef("", "", "string", unit)
    val tr = sumTypeRef(left, right, unit)
    assertEqual(tr.tag, "SumTypeRef")
    val l = tr.lhs as TypeRef
    val r = tr.rhs as TypeRef
    assertEqual(l.tag, "TypeNameRef")
    assertEqual(r.tag, "TypeNameRef")
}

test("TypeRef - TypeConstructorRef") {
    val base = typeNameRef("", "", "array", unit)
    val param = typeNameRef("", "", "int", unit)
    val tr = typeConstructorRef(base, [param], unit)
    assertEqual(tr.tag, "TypeConstructorRef")
    assertEqual(tr.typeParameters.size(), 1)
}

test("Supporting types - FormalArgument") {
    val tRef = typeNameRef("", "", "int", unit)
    val arg = newFormalArgument("x", tRef, unit, unit)
    assertEqual(arg.name, "x")
}

test("Supporting types - ParseRecordField") {
    val v = parseLongValue(42, unit)
    val rf = newParseRecordField("count", v)
    assertEqual(rf.name, "count")
}

test("ParseAst - literals") {
    val u = parseUnitValue(unit)
    assertEqual(u.tag, "UnitValue")

    val sec = newSection(1, 1, 1, 3)
    val lv = parseLongValue(42, sec)
    assertEqual(lv.tag, "LongValue")
    assertEqual(lv.longValue, 42)

    val bv = parseBoolValue(true, unit)
    assertEqual(bv.tag, "BoolValue")
    assertTrue(bv.boolValue)

    val sv = parseStringValue("hello", unit)
    assertEqual(sv.tag, "StringValue")
    assertEqual(sv.stringValue, "hello")
}

test("ParseAst - ParseVariableRead") {
    val vr = parseVariableRead("myVar", unit)
    assertEqual(vr.tag, "ParseVariableRead")
    assertEqual(vr.variableName, "myVar")
}

test("ParseAst - ParseFnCall") {
    val fn_ = parseVariableRead("foo", unit)
    val arg1 = parseLongValue(1, unit)
    val arg2 = parseLongValue(2, unit)
    val call = parseFnCall(fn_, [], [arg1, arg2], unit)
    assertEqual(call.tag, "ParseFnCall")
    assertEqual(call.arguments.size(), 2)
}

test("ParseAst - ParseIfElse") {
    val cond = parseBoolValue(true, unit)
    val thenB = parseLongValue(1, unit)
    val elseB = parseLongValue(2, unit)
    val ie = parseIfElse(cond, thenB, elseB, unit)
    assertEqual(ie.tag, "ParseIfElse")
    assertEqual((ie.condition as ParseAst).tag, "BoolValue")
    assertEqual((ie.thenBody as ParseAst).tag, "LongValue")
    assertEqual((ie.elseBody as ParseAst).tag, "LongValue")
}

test("ParseAst - ParseBlock") {
    val s1 = parseLongValue(1, unit)
    val s2 = parseLongValue(2, unit)
    val blk = parseBlock([s1, s2], unit)
    assertEqual(blk.tag, "ParseBlock")
    assertEqual(blk.body.size(), 2)
}

test("ParseAst - ParseBinaryOp") {
    val l = parseLongValue(1, unit)
    val r = parseLongValue(2, unit)
    val binop = parseBinaryOp("+", l, r, unit)
    assertEqual(binop.tag, "ParseBinaryOp")
    assertEqual(binop.op, "+")
    assertEqual((binop.left as ParseAst).tag, "LongValue")
    assertEqual((binop.right as ParseAst).tag, "LongValue")
}

test("ParseAst - ParseNameDeclaration") {
    val v = parseLongValue(10, unit)
    val decl = parseNameDeclaration(false, "x", true, unit, v, unit, unit)
    assertEqual(decl.tag, "ParseNameDeclaration")
    assertEqual(decl.symbolName, "x")
    assertTrue(decl.isMutable)
    assertFalse(decl.isPublic)
}

test("ParseAst - break and continue") {
    val brk = parseBreak(unit)
    assertEqual(brk.tag, "ParseBreak")
    val cont = parseContinue(unit)
    assertEqual(cont.tag, "ParseContinue")
}

test("ParseAst - ParseCreateArray and ParseCreateRecord") {
    val v1 = parseLongValue(1, unit)
    val v2 = parseLongValue(2, unit)
    val arr = parseCreateArray([v1, v2], unit)
    assertEqual(arr.tag, "ParseCreateArray")
    assertEqual(arr.arrayValues.size(), 2)

    val f1 = newParseRecordField("a", v1)
    val rec = parseCreateRecord([f1], unit)
    assertEqual(rec.tag, "ParseCreateRecord")
    assertEqual(rec.recordFields.size(), 1)
}

summary()
