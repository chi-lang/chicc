import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/types { Type, newTypeId, typeIdToString, anyTypeId, intTypeId, stringTypeId, tInt, tString, tUnit, tBool, tAny, primitiveType, functionType, recordType, sumType, arrayType, variableType }
import std/lang.array { size }

test("newTypeId") {
    val id = newTypeId("std", "lang.int", "int")
    assertEqual(id.moduleName, "std")
    assertEqual(id.packageName, "lang.int")
    assertEqual(id.name, "int")
}

test("typeIdToString") {
    val id = newTypeId("std", "lang.int", "int")
    assertEqual(typeIdToString(id), "std::lang.int::int")
}

test("typeIdEquals") {
    val a = newTypeId("std", "lang.int", "int")
    val b = newTypeId("std", "lang.int", "int")
    val c = newTypeId("std", "lang.string", "string")
    assertTrue(a.typeIdEquals(b))
    assertFalse(a.typeIdEquals(c))
}

test("primitiveType") {
    assertTrue(tInt.tag == "primitive")
    assertTrue(tString.tag == "primitive")
    assertEqual(tInt.tag, "primitive")
}

test("functionType") {
    val ft = functionType([tInt, tString], [], 0)
    assertTrue(ft.tag == "fn")
    assertEqual(ft.types.size(), 2)
    assertEqual(ft.defaults, 0)
}

test("recordType") {
    val r = recordType([], [{ name: "x", fieldType: tInt }], [])
    assertTrue(r.tag == "record")
    assertEqual(r.fields.size(), 1)
}

test("sumType") {
    val s = sumType([], tInt, tString, [])
    assertTrue(s.tag == "sum")
}

test("arrayType") {
    val a = arrayType(tInt, [])
    assertTrue(a.tag == "array")
}

test("variableType") {
    val v = variableType("T", 0)
    assertTrue(v.tag == "var")
    assertEqual(v.name, "T")
}

summary()
