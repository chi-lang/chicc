import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/types { newTypeId, typeIdToString, anyTypeId, intTypeId, stringTypeId, tInt, tString, tUnit, tBool, tAny, primitiveType, functionType, recordType, sumType, arrayType, variableType }

test("newTypeId") {
    val id = newTypeId("std", "lang.int", "int")
    assertEqual(id.moduleName, "std")
    assertEqual(id.packageName, "lang.int")
    assertEqual(id.name, "int")
}

test("typeIdToString") {
    val id = newTypeId("std", "lang.int", "int")
    assertEqual(typeIdToString(id), "std::lang.int::int")
}

test("typeIdEquals") {
    val a = newTypeId("std", "lang.int", "int")
    val b = newTypeId("std", "lang.int", "int")
    val c = newTypeId("std", "lang.string", "string")
    assertTrue(a.typeIdEquals(b))
    assertFalse(a.typeIdEquals(c))
}

test("primitiveType") {
    assertTrue(tInt.isPrimitive())
    assertTrue(tString.isPrimitive())
    assertEqual(tInt.typeTag(), "primitive")
}

test("functionType") {
    val ft = functionType([tInt, tString], [], 0)
    assertTrue(ft.isFunction())
    assertEqual(ft.typeTypesCount(), 2)
    assertEqual(ft.typeDefaults(), 0)
}

test("recordType") {
    val r = recordType([], [{ name: "x", fieldType: tInt }], [])
    assertTrue(r.isRecord())
    assertEqual(r.typeFieldsCount(), 1)
}

test("sumType") {
    val s = sumType([], tInt, tString, [])
    assertTrue(s.isSum())
}

test("arrayType") {
    val a = arrayType(tInt, [])
    assertTrue(a.isArray())
}

test("variableType") {
    val v = variableType("T", 0)
    assertTrue(v.isVariable())
    assertEqual(v.typeName(), "T")
}

summary()
