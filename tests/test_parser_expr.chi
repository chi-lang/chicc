import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/token { Token, newToken, TK_INT, TK_FLOAT, TK_STRING, TK_TRUE, TK_FALSE, TK_UNIT, TK_ID, TK_PLUS, TK_MINUS, TK_STAR, TK_SLASH, TK_PERCENT, TK_EQEQ, TK_NEQ, TK_LT, TK_LTEQ, TK_GT, TK_GTEQ, TK_NOT, TK_AND, TK_OR, TK_AMP, TK_PIPE, TK_LSHIFT, TK_RSHIFT, TK_WEAVE, TK_UNDERSCORE, TK_DOT, TK_COMMA, TK_COLON, TK_EQ, TK_PLUSEQ, TK_MINUSEQ, TK_STAREQ, TK_SLASHEQ, TK_LPAREN, TK_RPAREN, TK_LBRACE, TK_RBRACE, TK_LBRACKET, TK_RBRACKET, TK_RETURN, TK_BREAK, TK_CONTINUE, TK_EOF, TK_NEWLINE }
import chicc/parser { newParser, parseExpression, parseExpr }
import chicc/parse_ast { paTag, paLongValue, paFloatValue, paBoolValue, paStringValue, paVariableName, paOp, paLeft, paRight, paValue, paReturnValue, paArrayValues, paRecordFields, paCallee, paArguments, paReceiverName, paMemberName, paReceiver, paVariable, paIndexExpr, paIndexValue }

fn tk(kind: int, value: string): Token { newToken(kind, value, unit) }
fn eof(): Token { newToken(TK_EOF, "", unit) }

// --- Atom Parsing ---

test("parse integer literal") {
    val tokens = [tk(TK_INT, "42"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "LongValue")
    assertEqual(paLongValue(result), 42)
}

test("parse float literal") {
    val tokens = [tk(TK_FLOAT, "3.14"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "FloatValue")
}

test("parse string literal") {
    val tokens = [tk(TK_STRING, "hello"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "StringValue")
    assertEqual(paStringValue(result), "hello")
}

test("parse true literal") {
    val tokens = [tk(TK_TRUE, "true"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "BoolValue")
    assertEqual(paBoolValue(result), true)
}

test("parse false literal") {
    val tokens = [tk(TK_FALSE, "false"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "BoolValue")
    assertEqual(paBoolValue(result), false)
}

test("parse unit literal") {
    val tokens = [tk(TK_UNIT, "unit"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "UnitValue")
}

test("parse identifier") {
    val tokens = [tk(TK_ID, "myVar"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseVariableRead")
    assertEqual(paVariableName(result), "myVar")
}

test("parse weave placeholder") {
    val tokens = [tk(TK_UNDERSCORE, "_"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseWeavePlaceholder")
}

// --- Unary Operators ---

test("parse unary not") {
    val tokens = [tk(TK_NOT, "!"), tk(TK_TRUE, "true"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseNot")
    assertEqual(paTag(paValue(result)), "BoolValue")
}

test("parse unary minus") {
    val tokens = [tk(TK_MINUS, "-"), tk(TK_INT, "5"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "-")
    assertEqual(paLongValue(paLeft(result)), 0)
    assertEqual(paLongValue(paRight(result)), 5)
}

// --- Binary Operators ---

test("parse addition") {
    val tokens = [tk(TK_INT, "1"), tk(TK_PLUS, "+"), tk(TK_INT, "2"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "+")
    assertEqual(paLongValue(paLeft(result)), 1)
    assertEqual(paLongValue(paRight(result)), 2)
}

test("parse subtraction") {
    val tokens = [tk(TK_INT, "5"), tk(TK_MINUS, "-"), tk(TK_INT, "3"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "-")
    assertEqual(paLongValue(paLeft(result)), 5)
    assertEqual(paLongValue(paRight(result)), 3)
}

test("parse multiplication") {
    val tokens = [tk(TK_INT, "2"), tk(TK_STAR, "*"), tk(TK_INT, "3"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "*")
}

test("parse division") {
    val tokens = [tk(TK_INT, "10"), tk(TK_SLASH, "/"), tk(TK_INT, "2"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "/")
}

test("parse modulo") {
    val tokens = [tk(TK_INT, "10"), tk(TK_PERCENT, "%"), tk(TK_INT, "3"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "%")
}

test("parse equality") {
    val tokens = [tk(TK_ID, "x"), tk(TK_EQEQ, "=="), tk(TK_INT, "0"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "==")
}

test("parse not equal") {
    val tokens = [tk(TK_ID, "x"), tk(TK_NEQ, "!="), tk(TK_INT, "0"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "!=")
}

test("parse less than") {
    val tokens = [tk(TK_ID, "x"), tk(TK_LT, "<"), tk(TK_INT, "5"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "<")
}

test("parse logical and") {
    val tokens = [tk(TK_TRUE, "true"), tk(TK_AND, "&&"), tk(TK_FALSE, "false"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "&&")
}

test("parse logical or") {
    val tokens = [tk(TK_TRUE, "true"), tk(TK_OR, "||"), tk(TK_FALSE, "false"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "||")
}

// --- Operator Precedence ---

test("precedence: * binds tighter than +") {
    // 1 + 2 * 3 should parse as 1 + (2 * 3)
    val tokens = [tk(TK_INT, "1"), tk(TK_PLUS, "+"), tk(TK_INT, "2"), tk(TK_STAR, "*"), tk(TK_INT, "3"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "+")
    assertEqual(paLongValue(paLeft(result)), 1)
    // Right side should be 2 * 3
    val rhs = paRight(result)
    assertEqual(paTag(rhs), "ParseBinaryOp")
    assertEqual(paOp(rhs), "*")
    assertEqual(paLongValue(paLeft(rhs)), 2)
    assertEqual(paLongValue(paRight(rhs)), 3)
}

test("precedence: && binds tighter than ||") {
    // a || b && c should parse as a || (b && c)
    val tokens = [tk(TK_ID, "a"), tk(TK_OR, "||"), tk(TK_ID, "b"), tk(TK_AND, "&&"), tk(TK_ID, "c"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "||")
    assertEqual(paVariableName(paLeft(result)), "a")
    val rhs = paRight(result)
    assertEqual(paTag(rhs), "ParseBinaryOp")
    assertEqual(paOp(rhs), "&&")
}

test("precedence: left-to-right association for + ") {
    // 1 + 2 + 3 should parse as (1 + 2) + 3
    val tokens = [tk(TK_INT, "1"), tk(TK_PLUS, "+"), tk(TK_INT, "2"), tk(TK_PLUS, "+"), tk(TK_INT, "3"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "+")
    assertEqual(paLongValue(paRight(result)), 3)
    val lhs = paLeft(result)
    assertEqual(paTag(lhs), "ParseBinaryOp")
    assertEqual(paOp(lhs), "+")
    assertEqual(paLongValue(paLeft(lhs)), 1)
    assertEqual(paLongValue(paRight(lhs)), 2)
}

// --- Grouped Expressions ---

test("parse grouped expression") {
    // (1 + 2) * 3
    val tokens = [tk(TK_LPAREN, "("), tk(TK_INT, "1"), tk(TK_PLUS, "+"), tk(TK_INT, "2"), tk(TK_RPAREN, ")"), tk(TK_STAR, "*"), tk(TK_INT, "3"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "*")
    // left should be a group containing 1+2
    val grp = paLeft(result)
    assertEqual(paTag(grp), "ParseGroup")
}

// --- Array Literal ---

test("parse empty array") {
    val tokens = [tk(TK_LBRACKET, "["), tk(TK_RBRACKET, "]"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseCreateArray")
    assertEqual(paArrayValues(result).size(), 0)
}

test("parse array with values") {
    val tokens = [tk(TK_LBRACKET, "["), tk(TK_INT, "1"), tk(TK_COMMA, ","), tk(TK_INT, "2"), tk(TK_COMMA, ","), tk(TK_INT, "3"), tk(TK_RBRACKET, "]"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseCreateArray")
    assertEqual(paArrayValues(result).size(), 3)
}

// --- Record Literal ---

test("parse record literal") {
    // { name: "hello", age: 42 }
    val tokens = [
        tk(TK_LBRACE, "{"), tk(TK_ID, "name"), tk(TK_COLON, ":"), tk(TK_STRING, "hello"),
        tk(TK_COMMA, ","), tk(TK_ID, "age"), tk(TK_COLON, ":"), tk(TK_INT, "42"),
        tk(TK_RBRACE, "}"), eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseCreateRecord")
    assertEqual(paRecordFields(result).size(), 2)
}

// --- Field Access ---

test("parse field access") {
    // x.name
    val tokens = [tk(TK_ID, "x"), tk(TK_DOT, "."), tk(TK_ID, "name"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseFieldAccess")
    assertEqual(paReceiverName(result), "x")
    assertEqual(paMemberName(result), "name")
}

test("parse chained field access") {
    // a.b.c
    val tokens = [tk(TK_ID, "a"), tk(TK_DOT, "."), tk(TK_ID, "b"), tk(TK_DOT, "."), tk(TK_ID, "c"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseFieldAccess")
    assertEqual(paMemberName(result), "c")
    val recv = paReceiver(result)
    assertEqual(paTag(recv), "ParseFieldAccess")
    assertEqual(paMemberName(recv), "b")
}

// --- Index Access ---

test("parse index access") {
    // arr[1]
    val tokens = [tk(TK_ID, "arr"), tk(TK_LBRACKET, "["), tk(TK_INT, "1"), tk(TK_RBRACKET, "]"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseIndexOperator")
    assertEqual(paTag(paVariable(result)), "ParseVariableRead")
    assertEqual(paLongValue(paIndexExpr(result)), 1)
}

// --- Function Call ---

test("parse function call no args") {
    // foo()
    val tokens = [tk(TK_ID, "foo"), tk(TK_LPAREN, "("), tk(TK_RPAREN, ")"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseFnCall")
    assertEqual(paVariableName(paCallee(result)), "foo")
    assertEqual(paArguments(result).size(), 0)
}

test("parse function call with args") {
    // add(1, 2)
    val tokens = [tk(TK_ID, "add"), tk(TK_LPAREN, "("), tk(TK_INT, "1"), tk(TK_COMMA, ","), tk(TK_INT, "2"), tk(TK_RPAREN, ")"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseFnCall")
    assertEqual(paArguments(result).size(), 2)
}

test("parse UFCS call") {
    // x.foo(1)
    val tokens = [tk(TK_ID, "x"), tk(TK_DOT, "."), tk(TK_ID, "foo"), tk(TK_LPAREN, "("), tk(TK_INT, "1"), tk(TK_RPAREN, ")"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    // x.foo is parsed as field access, then (1) makes it a fn call
    assertEqual(paTag(result), "ParseFnCall")
    assertEqual(paArguments(result).size(), 1)
    val callee = paCallee(result)
    assertEqual(paTag(callee), "ParseFieldAccess")
    assertEqual(paMemberName(callee), "foo")
}

// --- Assignment ---

test("parse assignment") {
    // x = 42
    val tokens = [tk(TK_ID, "x"), tk(TK_EQ, "="), tk(TK_INT, "42"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseAssignment")
    assertEqual(paVariableName(result), "x")
    assertEqual(paLongValue(paValue(result)), 42)
}

test("parse op-assignment +=") {
    // x += 1
    val tokens = [tk(TK_ID, "x"), tk(TK_PLUSEQ, "+="), tk(TK_INT, "1"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseAssignment")
    assertEqual(paVariableName(result), "x")
    // value should be a binary op: x + 1
    val binOp = paValue(result)
    assertEqual(paTag(binOp), "ParseBinaryOp")
    assertEqual(paOp(binOp), "+")
}

test("parse field assignment") {
    // obj.x = 10
    val tokens = [tk(TK_ID, "obj"), tk(TK_DOT, "."), tk(TK_ID, "x"), tk(TK_EQ, "="), tk(TK_INT, "10"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseFieldAssignment")
    assertEqual(paReceiverName(result), "obj")
    assertEqual(paMemberName(result), "x")
}

test("parse indexed assignment") {
    // arr[1] = 10
    val tokens = [tk(TK_ID, "arr"), tk(TK_LBRACKET, "["), tk(TK_INT, "1"), tk(TK_RBRACKET, "]"), tk(TK_EQ, "="), tk(TK_INT, "10"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseIndexedAssignment")
}

// --- Weave ---

test("parse weave operator") {
    // x ~> foo(_)
    val tokens = [tk(TK_ID, "x"), tk(TK_WEAVE, "~>"), tk(TK_ID, "foo"), tk(TK_LPAREN, "("), tk(TK_UNDERSCORE, "_"), tk(TK_RPAREN, ")"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseWeave")
}

// --- Return, Break, Continue ---

test("parse return with value") {
    val tokens = [tk(TK_RETURN, "return"), tk(TK_INT, "42"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseReturn")
    assertEqual(paLongValue(paReturnValue(result)), 42)
}

test("parse return without value") {
    val tokens = [tk(TK_RETURN, "return"), tk(TK_NEWLINE, "\n"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseReturn")
    assertEqual(paTag(paReturnValue(result)), "UnitValue")
}

test("parse break") {
    val tokens = [tk(TK_BREAK, "break"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBreak")
}

test("parse continue") {
    val tokens = [tk(TK_CONTINUE, "continue"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseContinue")
}

// --- Shift Operators ---

test("parse left shift") {
    val tokens = [tk(TK_INT, "1"), tk(TK_LSHIFT, "<<"), tk(TK_INT, "4"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "<<")
}

test("parse right shift") {
    val tokens = [tk(TK_INT, "16"), tk(TK_RSHIFT, ">>"), tk(TK_INT, "2"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), ">>")
}

// --- Bitwise Operators ---

test("parse bitwise and") {
    val tokens = [tk(TK_INT, "5"), tk(TK_AMP, "&"), tk(TK_INT, "3"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "&")
}

test("parse bitwise or") {
    val tokens = [tk(TK_INT, "5"), tk(TK_PIPE, "|"), tk(TK_INT, "3"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "|")
}

// --- Complex Expressions ---

test("complex: 1 + 2 * 3 - 4") {
    // Should parse as (1 + (2*3)) - 4
    val tokens = [
        tk(TK_INT, "1"), tk(TK_PLUS, "+"), tk(TK_INT, "2"), tk(TK_STAR, "*"), tk(TK_INT, "3"),
        tk(TK_MINUS, "-"), tk(TK_INT, "4"), eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "-")
    assertEqual(paLongValue(paRight(result)), 4)
    val lhs = paLeft(result)
    assertEqual(paTag(lhs), "ParseBinaryOp")
    assertEqual(paOp(lhs), "+")
}

test("method chain: x.foo().bar()") {
    val tokens = [
        tk(TK_ID, "x"), tk(TK_DOT, "."), tk(TK_ID, "foo"),
        tk(TK_LPAREN, "("), tk(TK_RPAREN, ")"),
        tk(TK_DOT, "."), tk(TK_ID, "bar"),
        tk(TK_LPAREN, "("), tk(TK_RPAREN, ")"), eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    // Should be fnCall(fieldAccess(fnCall(fieldAccess(x, foo)), bar))
    assertEqual(paTag(result), "ParseFnCall")
    val callee = paCallee(result)
    assertEqual(paTag(callee), "ParseFieldAccess")
    assertEqual(paMemberName(callee), "bar")
}

test("parse comparison operators") {
    // x <= 10
    val tokens = [tk(TK_ID, "x"), tk(TK_LTEQ, "<="), tk(TK_INT, "10"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), "<=")
}

test("parse >= operator") {
    val tokens = [tk(TK_ID, "x"), tk(TK_GTEQ, ">="), tk(TK_INT, "10"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), ">=")
}

test("parse > operator") {
    val tokens = [tk(TK_ID, "x"), tk(TK_GT, ">"), tk(TK_INT, "10"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseBinaryOp")
    assertEqual(paOp(result), ">")
}

test("parse op-assignment -=") {
    val tokens = [tk(TK_ID, "x"), tk(TK_MINUSEQ, "-="), tk(TK_INT, "5"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseAssignment")
    val binOp = paValue(result)
    assertEqual(paOp(binOp), "-")
}

test("parse op-assignment *=") {
    val tokens = [tk(TK_ID, "x"), tk(TK_STAREQ, "*="), tk(TK_INT, "2"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseAssignment")
    val binOp = paValue(result)
    assertEqual(paOp(binOp), "*")
}

test("parse op-assignment /=") {
    val tokens = [tk(TK_ID, "x"), tk(TK_SLASHEQ, "/="), tk(TK_INT, "2"), eof()]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseAssignment")
    val binOp = paValue(result)
    assertEqual(paOp(binOp), "/")
}

summary()
