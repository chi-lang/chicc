import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/types { Type, TypeId, RecordField, tAny, tUnit, tBool, tInt, tFloat, tString, primitiveType, functionType, recordType, sumType, arrayType, variableType, recursiveType, intTypeId, stringTypeId, boolTypeId, floatTypeId, unitTypeId }
import chicc/unification { Constraint, Binding, newConstraint, constraintWithReplacedVariable, unify, tryUnify }
import chicc/source { newSection, Section }
import std/lang { luaExpr, embedLua }

val testSection = newSection(1, 1, 1, 10)

// --- Constraint type ---

test("newConstraint: creates constraint with expected, actual, section, history") {
    val c = newConstraint(tInt, tString, testSection, [])
    val exp: Type = luaExpr("c.expected")
    val act: Type = luaExpr("c.actual")
    assertTrue(exp.typeEquals(tInt))
    assertTrue(act.typeEquals(tString))
}

test("newConstraint: with unit section") {
    val c = newConstraint(tInt, tString, unit, [])
    val sec: any = luaExpr("c.section")
    val isNil: bool = luaExpr("sec == nil")
    assertTrue(isNil)
}

// --- constraintWithReplacedVariable ---

test("constraintWithReplacedVariable: replaces variable in expected and actual") {
    val v = variableType("T", 0)
    val c = newConstraint(v, functionType([v, tString], [], 0), testSection, [])
    val replaced = constraintWithReplacedVariable(c, v, tInt)
    val exp: Type = luaExpr("replaced.expected")
    val act: Type = luaExpr("replaced.actual")
    assertTrue(exp.typeEquals(tInt))
    val expectedAct = functionType([tInt, tString], [], 0)
    assertTrue(act.typeEquals(expectedAct))
}

test("constraintWithReplacedVariable: no-op when variable not present") {
    val v = variableType("T", 0)
    val c = newConstraint(tInt, tString, testSection, [])
    val replaced = constraintWithReplacedVariable(c, v, tBool)
    val exp: Type = luaExpr("replaced.expected")
    val act: Type = luaExpr("replaced.actual")
    assertTrue(exp.typeEquals(tInt))
    assertTrue(act.typeEquals(tString))
}

// --- unify: basic cases ---

test("unify: equal types produce no solutions") {
    val c = newConstraint(tInt, tInt, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    val count: int = luaExpr("#solutions")
    assertEqual(count, 0)
}

test("unify: expected is any produces no solutions") {
    val c = newConstraint(tAny, tString, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    val count: int = luaExpr("#solutions")
    assertEqual(count, 0)
}

test("unify: variable expected resolves to actual") {
    val v = variableType("T", 0)
    val c = newConstraint(v, tInt, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    val count: int = luaExpr("#solutions")
    assertEqual(count, 1)
    val sol: any = luaExpr("solutions[1]")
    val solVar: Type = luaExpr("sol.variable")
    val solRepl: Type = luaExpr("sol.replacement")
    assertTrue(solVar.typeEquals(v))
    assertTrue(solRepl.typeEquals(tInt))
}

test("unify: variable actual resolves to expected") {
    val v = variableType("T", 0)
    val c = newConstraint(tString, v, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    val count: int = luaExpr("#solutions")
    assertEqual(count, 1)
    val sol: any = luaExpr("solutions[1]")
    val solVar: Type = luaExpr("sol.variable")
    val solRepl: Type = luaExpr("sol.replacement")
    assertTrue(solVar.typeEquals(v))
    assertTrue(solRepl.typeEquals(tString))
}

// --- unify: primitive mismatch ---

test("unify: mismatched primitives throws typeMismatch") {
    val c = newConstraint(tInt, tString, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    embedLua("local ok, err = pcall(unify, constraints)")
    val ok: bool = luaExpr("ok")
    assertFalse(ok)
    val code: string = luaExpr("err.code")
    assertEqual(code, "TYPE_MISMATCH")
}

// --- unify: function types ---

test("unify: matching function types") {
    val v1 = variableType("T", 0)
    val v2 = variableType("U", 0)
    val expected = functionType([v1, v2], [], 0)
    val actual = functionType([tInt, tString], [], 0)
    val c = newConstraint(expected, actual, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    val count: int = luaExpr("#solutions")
    assertEqual(count, 2)
}

test("unify: function arity mismatch throws error") {
    val expected = functionType([tInt, tString], [], 0)
    val actual = functionType([tInt, tString, tBool], [], 0)
    val c = newConstraint(expected, actual, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    embedLua("local ok, err = pcall(unify, constraints)")
    val ok: bool = luaExpr("ok")
    assertFalse(ok)
    val code: string = luaExpr("err.code")
    assertEqual(code, "FUNCTION_ARITY_ERROR")
}

test("unify: void return accepts anything") {
    // Function with unit return type should accept any actual return type
    val expected = functionType([tInt, tUnit], [], 0)
    val actual = functionType([tInt, tString], [], 0)
    val c = newConstraint(expected, actual, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    // Should succeed - no error
    val count: int = luaExpr("#solutions")
    assertEqual(count, 0)
}

test("unify: void return does NOT skip if actual is variable") {
    val v = variableType("T", 0)
    val expected = functionType([tInt, tUnit], [], 0)
    val actual = functionType([tInt, v], [], 0)
    val c = newConstraint(expected, actual, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    // Should solve the variable to unit
    val count: int = luaExpr("#solutions")
    assertEqual(count, 1)
    val sol: any = luaExpr("solutions[1]")
    val solRepl: Type = luaExpr("sol.replacement")
    assertTrue(solRepl.typeEquals(tUnit))
}

// --- unify: record types ---

test("unify: matching record types") {
    val v = variableType("T", 0)
    val expected = recordType([], [{ name: "x", fieldType: v }], [])
    val actual = recordType([], [{ name: "x", fieldType: tInt }], [])
    val c = newConstraint(expected, actual, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    val count: int = luaExpr("#solutions")
    assertEqual(count, 1)
    val sol: any = luaExpr("solutions[1]")
    val solRepl: Type = luaExpr("sol.replacement")
    assertTrue(solRepl.typeEquals(tInt))
}

test("unify: record missing field throws error") {
    val expected = recordType([], [{ name: "x", fieldType: tInt }, { name: "y", fieldType: tString }], [])
    val actual = recordType([], [{ name: "x", fieldType: tInt }], [])
    val c = newConstraint(expected, actual, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    embedLua("local ok, err = pcall(unify, constraints)")
    val ok: bool = luaExpr("ok")
    assertFalse(ok)
    val code: string = luaExpr("err.code")
    assertEqual(code, "TYPE_MISMATCH")
}

// --- unify: array types ---

test("unify: matching array types") {
    val v = variableType("T", 0)
    val expected = arrayType(v, [])
    val actual = arrayType(tInt, [])
    val c = newConstraint(expected, actual, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    val count: int = luaExpr("#solutions")
    assertEqual(count, 1)
    val sol: any = luaExpr("solutions[1]")
    val solRepl: Type = luaExpr("sol.replacement")
    assertTrue(solRepl.typeEquals(tInt))
}

// --- unify: sum types ---

test("unify: sum type tries rhs first") {
    // sum(int, string) expected, string actual -> should match via rhs
    val sumT = sumType([], tInt, tString, [])
    val c = newConstraint(sumT, tString, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    // string == string -> no solutions needed
    val count: int = luaExpr("#solutions")
    assertEqual(count, 0)
}

test("unify: sum type falls back to lhs") {
    // sum(int, string) expected, int actual -> rhs fails, lhs matches
    val sumT = sumType([], tInt, tString, [])
    val c = newConstraint(sumT, tInt, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    val count: int = luaExpr("#solutions")
    assertEqual(count, 0)
}

test("unify: sum type with variable") {
    val v = variableType("T", 0)
    val sumT = sumType([], tInt, v, [])
    val c = newConstraint(sumT, tString, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    // rhs is v, so v should unify with tString
    val count: int = luaExpr("#solutions")
    assertEqual(count, 1)
    val sol: any = luaExpr("solutions[1]")
    val solVar: Type = luaExpr("sol.variable")
    val solRepl: Type = luaExpr("sol.replacement")
    assertTrue(solVar.typeEquals(v))
    assertTrue(solRepl.typeEquals(tString))
}

// --- unify: recursive types ---

test("unify: recursive type gets unfolded") {
    val v = variableType("X", 0)
    val inner = functionType([tInt, v], [], 0)
    val recType = recursiveType(v, inner)
    val v2 = variableType("T", 0)
    val c = newConstraint(recType, v2, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    val solutions = unify(constraints)
    // The recursive type unfolds: fn(int, recType)
    // Then v2 should be assigned to the unfolded type
    val count: int = luaExpr("#solutions")
    assertTrue(count >= 1)
}

// --- unify: not a function ---

test("unify: function expected but non-function actual throws notAFunction") {
    val expected = functionType([tInt, tString], [], 0)
    val c = newConstraint(expected, tInt, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    embedLua("local ok, err = pcall(unify, constraints)")
    val ok: bool = luaExpr("ok")
    assertFalse(ok)
    val code: string = luaExpr("err.code")
    assertEqual(code, "NOT_A_FUNCTION")
}

// --- unify: infinite type ---

test("unify: infinite type throws error") {
    val v = variableType("T", 0)
    // T = fn(T, int) -> occurs check should catch this
    val fnType = functionType([v, tInt], [], 0)
    val c = newConstraint(v, fnType, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    embedLua("local ok, err = pcall(unify, constraints)")
    val ok: bool = luaExpr("ok")
    assertFalse(ok)
    val code: string = luaExpr("err.code")
    assertEqual(code, "INFINITE_TYPE")
}

// --- unify: variable propagation ---

test("unify: variable solution propagates to remaining constraints") {
    val v = variableType("T", 0)
    val c1 = newConstraint(v, tInt, testSection, [])
    val c2 = newConstraint(v, tString, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c1)")
    embedLua("table.insert(constraints, c2)")
    // After solving T=int, second constraint becomes int=string -> mismatch
    embedLua("local ok, err = pcall(unify, constraints)")
    val ok: bool = luaExpr("ok")
    assertFalse(ok)
    val code: string = luaExpr("err.code")
    assertEqual(code, "TYPE_MISMATCH")
}

test("unify: multiple variables resolved") {
    val v1 = variableType("T", 0)
    val v2 = variableType("U", 0)
    val c1 = newConstraint(v1, tInt, testSection, [])
    val c2 = newConstraint(v2, tString, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c1)")
    embedLua("table.insert(constraints, c2)")
    val solutions = unify(constraints)
    val count: int = luaExpr("#solutions")
    assertEqual(count, 2)
}

// --- unify: else case (tag mismatch) ---

test("unify: mismatched tags throws typeMismatch") {
    // record vs array
    val rec = recordType([], [{ name: "x", fieldType: tInt }], [])
    val arr = arrayType(tInt, [])
    val c = newConstraint(rec, arr, testSection, [])
    val constraints: array[any] = luaExpr("{}")
    embedLua("table.insert(constraints, c)")
    embedLua("local ok, err = pcall(unify, constraints)")
    val ok: bool = luaExpr("ok")
    assertFalse(ok)
    val code: string = luaExpr("err.code")
    assertEqual(code, "TYPE_MISMATCH")
}

// --- unify: empty constraints ---

test("unify: empty constraints returns empty solutions") {
    val constraints: array[any] = luaExpr("{}")
    val solutions = unify(constraints)
    val count: int = luaExpr("#solutions")
    assertEqual(count, 0)
}

// --- unit strictness (issue #7) and any-intersection ---
// `unit` is not a silent inhabitant of records and sums. Absence of a
// value is only allowed where the type says so: `T | unit`.

test("unify: unit where a record is expected is a type error") {
    val rec = recordType([], [{ name: "x", fieldType: tInt }], [])
    val c = newConstraint(rec, tUnit, testSection, [])
    val constraints: array[any] = []
    constraints.push(c)
    embedLua("local ok, err = pcall(unify, constraints)")
    assertFalse(luaExpr("ok") as bool)
    assertEqual(luaExpr("err.code") as string, "TYPE_MISMATCH")
}

test("unify: a record where unit is expected is a type error") {
    val rec = recordType([], [{ name: "x", fieldType: tInt }], [])
    val c = newConstraint(tUnit, rec, testSection, [])
    val constraints: array[any] = []
    constraints.push(c)
    embedLua("local ok, err = pcall(unify, constraints)")
    assertFalse(luaExpr("ok") as bool)
    assertEqual(luaExpr("err.code") as string, "TYPE_MISMATCH")
}

test("unify: unit where a sum without a unit variant is expected is a type error") {
    val sumT = sumType([], tInt, tString, [])
    val c = newConstraint(sumT, tUnit, testSection, [])
    val constraints: array[any] = []
    constraints.push(c)
    embedLua("local ok, err = pcall(unify, constraints)")
    assertFalse(luaExpr("ok") as bool)
    assertEqual(luaExpr("err.code") as string, "TYPE_MISMATCH")
}

test("unify: unit where a recursive record is expected is a type error") {
    // Recursive types unfold before unit is considered, so this lands in
    // the record-vs-unit case after one unfolding step.
    val v = variableType("X", 0)
    val inner = recordType([], [{ name: "next", fieldType: v }], [])
    val recT = recursiveType(v, inner)
    val c = newConstraint(recT, tUnit, testSection, [])
    val constraints: array[any] = []
    constraints.push(c)
    embedLua("local ok, err = pcall(unify, constraints)")
    assertFalse(luaExpr("ok") as bool)
    assertEqual(luaExpr("err.code") as string, "TYPE_MISMATCH")
}

test("unify: unit unifies with a sum that has a unit variant") {
    val sumT = sumType([], tInt, tUnit, [])
    val c = newConstraint(sumT, tUnit, testSection, [])
    val constraints: array[any] = []
    constraints.push(c)
    // Resolves through normal sum branching — no error.
    val solutions = unify(constraints)
    assertEqual(solutions.size(), 0)
}

test("unify: actual any intersects a concrete primitive (no mismatch)") {
    // any is the top type; expected=int, actual=any must not error.
    val c = newConstraint(tInt, tAny, testSection, [])
    val constraints: array[any] = []
    constraints.push(c)
    val solutions = unify(constraints)
    assertEqual(solutions.size(), 0)
}

// --- tryUnify (issue #12): non-throwing trial unification ---
// Contract under test (docs/excavation/tryunify/): tryUnify answers
// "do these constraints unify?" as a value — success returns the
// bindings array (possibly empty; `[] != unit`), failure returns unit.
// Every failure arm of the unifier is pinned through BOTH facades:
// thrown with the right code via `unify`, `unit` via `tryUnify`
// (Phase 3 resolutions F2/F3/F6 — the type system cannot catch a
// polarity inversion or a dropped failure; only these tests can).

// Missing throwing-facade arm: the existing infinite-type test puts the
// variable on the EXPECTED side; this pins the actual-side occurs check.
test("unify: infinite type with variable on actual side throws error") {
    val v = variableType("T", 0)
    val fnType = functionType([v, tInt], [], 0)
    val c = newConstraint(fnType, v, testSection, [])
    val constraints: array[any] = []
    constraints.push(c)
    embedLua("local ok, err = pcall(unify, constraints)")
    assertFalse(luaExpr("ok") as bool)
    assertEqual(luaExpr("err.code") as string, "INFINITE_TYPE")
}

test("tryUnify: mismatched primitives returns unit") {
    val r = tryUnify([newConstraint(tInt, tString, testSection, [])])
    assertTrue(r == unit)
}

test("tryUnify: record missing field returns unit") {
    val expected = recordType([], [{ name: "x", fieldType: tInt }, { name: "y", fieldType: tString }], [])
    val actual = recordType([], [{ name: "x", fieldType: tInt }], [])
    val r = tryUnify([newConstraint(expected, actual, testSection, [])])
    assertTrue(r == unit)
}

test("tryUnify: infinite type with variable on expected side returns unit") {
    val v = variableType("T", 0)
    val fnType = functionType([v, tInt], [], 0)
    val r = tryUnify([newConstraint(v, fnType, testSection, [])])
    assertTrue(r == unit)
}

test("tryUnify: infinite type with variable on actual side returns unit") {
    val v = variableType("T", 0)
    val fnType = functionType([v, tInt], [], 0)
    val r = tryUnify([newConstraint(fnType, v, testSection, [])])
    assertTrue(r == unit)
}

test("tryUnify: function arity mismatch returns unit") {
    val expected = functionType([tInt, tString], [], 0)
    val actual = functionType([tInt, tString, tBool], [], 0)
    val r = tryUnify([newConstraint(expected, actual, testSection, [])])
    assertTrue(r == unit)
}

test("tryUnify: non-function actual against function expected returns unit") {
    val expected = functionType([tInt, tString], [], 0)
    val r = tryUnify([newConstraint(expected, tInt, testSection, [])])
    assertTrue(r == unit)
}

test("tryUnify: mismatched tags (record vs array) returns unit") {
    val rec = recordType([], [{ name: "x", fieldType: tInt }], [])
    val arr = arrayType(tInt, [])
    val r = tryUnify([newConstraint(rec, arr, testSection, [])])
    assertTrue(r == unit)
}

// Polarity pinning (F2): success must be distinguishable from failure
// even when there is nothing to bind — an empty array, never unit.
test("tryUnify: success with zero bindings returns empty array, not unit") {
    val r = tryUnify([newConstraint(tInt, tInt, testSection, [])])
    assertTrue(r != unit)
    val bindings = r as array[Binding]
    assertEqual(bindings.size(), 0)
}

test("tryUnify: empty constraints succeed with an empty bindings array") {
    val constraints: array[any] = []
    val r = tryUnify(constraints)
    assertTrue(r != unit)
    val bindings = r as array[Binding]
    assertEqual(bindings.size(), 0)
}

// Also pins the consumption idiom (F6/d): the FIRST comparison of
// tryUnify's DECLARED sum return type (array[Binding] | unit) against
// unit in the tree — native `!= unit` branch, then the trusting cast.
test("tryUnify: success with one binding returns variable and replacement") {
    val v = variableType("T", 0)
    val r = tryUnify([newConstraint(v, tInt, testSection, [])])
    assertTrue(r != unit)
    if r != unit {
        val bindings = r as array[Binding]
        assertEqual(bindings.size(), 1)
        assertTrue(bindings[1].variable.typeEquals(v))
        assertTrue(bindings[1].replacement.typeEquals(tInt))
    }
}

// Sum fallback with an OBSERVABLE binding (F6 vacuous-success killer):
// sum(T | string) vs int — rhs (string) is probed first and fails, the
// lhs fallback must actually run and bind T=int. A polarity-inverted
// probe would report rhs as vacuously successful, never queue the
// fallback, and produce zero bindings — caught here, through both
// facades. (The no-binding fallback case is already pinned by
// "unify: sum type falls back to lhs".)
test("unify: sum fallback binds a variable through lhs after rhs probe fails") {
    val v = variableType("T", 0)
    val sumT = sumType([], v, tString, [])
    val c = newConstraint(sumT, tInt, testSection, [])
    val constraints: array[any] = []
    constraints.push(c)
    val solutions = unify(constraints)
    assertEqual(solutions.size(), 1)
    assertTrue(solutions[1].variable.typeEquals(v))
    assertTrue(solutions[1].replacement.typeEquals(tInt))
}

test("tryUnify: sum fallback succeeds and returns the lhs binding") {
    val v = variableType("T", 0)
    val sumT = sumType([], v, tString, [])
    val r = tryUnify([newConstraint(sumT, tInt, testSection, [])])
    assertTrue(r != unit)
    if r != unit {
        val bindings = r as array[Binding]
        assertEqual(bindings.size(), 1)
        assertTrue(bindings[1].variable.typeEquals(v))
        assertTrue(bindings[1].replacement.typeEquals(tInt))
    }
}

summary()
