import chicc/test_util { test, assertEqual, summary }
import chicc/lexer { newLexer, lexReadString }
import chicc/token { TK_STRING, TK_INTERP_START, TK_INTERP_TEXT, TK_INTERP_EXPR_START, TK_INTERP_EXPR_END, TK_INTERP_END, TK_ID, TK_INT, TK_PLUS, TK_DOT, TK_LBRACE, TK_RBRACE, TK_COLON, TK_COMMA }
import std/lang.array { size }
import std/lang { luaExpr, embedLua }

// Helper: build a string containing dollar sign via Lua
fn dollar(): string { luaExpr("string.char(36)") }

// Helper: build test source strings containing dollar signs
// E.g., mkSrc("hello ", "name", "") => "\"hello $name\""
// wraps in quotes, puts dollar before ident
fn mkInterpSrc(before: string, ident: string, after: string): string {
    val d = dollar()
    luaExpr("'\"' .. before .. string.char(36) .. ident .. after .. '\"'")
}

// Helper: build ${expr} source strings
// E.g., mkExprSrc("", "1 + 2", "") => "\"${1 + 2}\""
fn mkExprSrc(before: string, expr: string, after: string): string {
    luaExpr("'\"' .. before .. string.char(36) .. '{' .. expr .. '}' .. after .. '\"'")
}

// === Simple strings (no interpolation) ===

test("simple string: hello") {
    val lex = newLexer("\"hello\"")
    lexReadString(lex)
    assertEqual(lex.tokens.size(), 1)
    assertEqual(lex.tokens[1].kind, TK_STRING)
    assertEqual(lex.tokens[1].value, "hello")
}

test("simple string: empty") {
    val lex = newLexer("\"\"")
    lexReadString(lex)
    assertEqual(lex.tokens.size(), 1)
    assertEqual(lex.tokens[1].kind, TK_STRING)
    assertEqual(lex.tokens[1].value, "")
}

test("simple string: single char") {
    val lex = newLexer("\"a\"")
    lexReadString(lex)
    assertEqual(lex.tokens[1].kind, TK_STRING)
    assertEqual(lex.tokens[1].value, "a")
}

test("simple string: spaces") {
    val lex = newLexer("\"hello world\"")
    lexReadString(lex)
    assertEqual(lex.tokens[1].kind, TK_STRING)
    assertEqual(lex.tokens[1].value, "hello world")
}

// === Escape sequences ===

test("escape: newline") {
    val src: string = luaExpr("'\"a\\\\nb\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    assertEqual(lex.tokens[1].kind, TK_STRING)
    val expected: string = luaExpr("'a\\nb'")
    assertEqual(lex.tokens[1].value, expected)
}

test("escape: tab") {
    val src: string = luaExpr("'\"a\\\\tb\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    assertEqual(lex.tokens[1].kind, TK_STRING)
    val expected: string = luaExpr("'a\\tb'")
    assertEqual(lex.tokens[1].value, expected)
}

test("escape: carriage return") {
    val src: string = luaExpr("'\"a\\\\rb\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    assertEqual(lex.tokens[1].kind, TK_STRING)
    val expected: string = luaExpr("'a\\rb'")
    assertEqual(lex.tokens[1].value, expected)
}

test("escape: backslash") {
    val src: string = luaExpr("'\"a\\\\\\\\b\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    assertEqual(lex.tokens[1].kind, TK_STRING)
    val expected: string = luaExpr("'a\\\\b'")
    assertEqual(lex.tokens[1].value, expected)
}

test("escape: quote") {
    val src: string = luaExpr("'\"a\\\\\"b\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    assertEqual(lex.tokens[1].kind, TK_STRING)
    val expected: string = luaExpr("'a\"b'")
    assertEqual(lex.tokens[1].value, expected)
}

test("escape: dollar sign") {
    // Source: "a\$b" - escaped dollar, no interpolation
    val src: string = luaExpr("'\"a\\\\' .. string.char(36) .. 'b\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    // Escaped dollar means no interpolation -> simple TK_STRING
    assertEqual(lex.tokens[1].kind, TK_STRING)
    val expected: string = luaExpr("'a' .. string.char(36) .. 'b'")
    assertEqual(lex.tokens[1].value, expected)
}

test("escape: null") {
    val src: string = luaExpr("'\"a\\\\0b\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    assertEqual(lex.tokens[1].kind, TK_STRING)
    val expected: string = luaExpr("'a\\0b'")
    assertEqual(lex.tokens[1].value, expected)
}

// === Simple identifier interpolation ===

test("interp: hello and name") {
    val src = mkInterpSrc("hello ", "name", "")
    val lex = newLexer(src)
    lexReadString(lex)
    assertEqual(lex.tokens.size(), 6)
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_TEXT)
    assertEqual(lex.tokens[2].value, "hello ")
    assertEqual(lex.tokens[3].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[4].kind, TK_ID)
    assertEqual(lex.tokens[4].value, "name")
    assertEqual(lex.tokens[5].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[6].kind, TK_INTERP_END)
}

test("interp: ident at start") {
    val src = mkInterpSrc("", "name", " world")
    val lex = newLexer(src)
    lexReadString(lex)
    // INTERP_START, EXPR_START, ID(name), EXPR_END, TEXT(" world"), INTERP_END
    assertEqual(lex.tokens.size(), 6)
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[3].kind, TK_ID)
    assertEqual(lex.tokens[3].value, "name")
    assertEqual(lex.tokens[4].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[5].kind, TK_INTERP_TEXT)
    assertEqual(lex.tokens[5].value, " world")
    assertEqual(lex.tokens[6].kind, TK_INTERP_END)
}

test("interp: a b c - mixed text and ident") {
    // "a $b c"
    val src = mkInterpSrc("a ", "b", " c")
    val lex = newLexer(src)
    lexReadString(lex)
    // INTERP_START, TEXT("a "), EXPR_START, ID("b"), EXPR_END, TEXT(" c"), INTERP_END
    assertEqual(lex.tokens.size(), 7)
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_TEXT)
    assertEqual(lex.tokens[2].value, "a ")
    assertEqual(lex.tokens[3].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[4].kind, TK_ID)
    assertEqual(lex.tokens[4].value, "b")
    assertEqual(lex.tokens[5].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[6].kind, TK_INTERP_TEXT)
    assertEqual(lex.tokens[6].value, " c")
    assertEqual(lex.tokens[7].kind, TK_INTERP_END)
}

test("interp: multiple vars") {
    // "$a and $b"
    val d = dollar()
    val src: string = luaExpr("'\"' .. string.char(36) .. 'a and ' .. string.char(36) .. 'b\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    // INTERP_START, EXPR_START, ID(a), EXPR_END, TEXT(" and "), EXPR_START, ID(b), EXPR_END, INTERP_END
    assertEqual(lex.tokens.size(), 9)
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[3].kind, TK_ID)
    assertEqual(lex.tokens[3].value, "a")
    assertEqual(lex.tokens[4].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[5].kind, TK_INTERP_TEXT)
    assertEqual(lex.tokens[5].value, " and ")
    assertEqual(lex.tokens[6].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[7].kind, TK_ID)
    assertEqual(lex.tokens[7].value, "b")
    assertEqual(lex.tokens[8].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[9].kind, TK_INTERP_END)
}

// === Expression interpolation ===

test("interp: expr 1 + 2") {
    val src = mkExprSrc("", "1 + 2", "")
    val lex = newLexer(src)
    lexReadString(lex)
    // INTERP_START, EXPR_START, INT(1), PLUS, INT(2), EXPR_END, INTERP_END
    assertEqual(lex.tokens.size(), 7)
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[3].kind, TK_INT)
    assertEqual(lex.tokens[3].value, "1")
    assertEqual(lex.tokens[4].kind, TK_PLUS)
    assertEqual(lex.tokens[5].kind, TK_INT)
    assertEqual(lex.tokens[5].value, "2")
    assertEqual(lex.tokens[6].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[7].kind, TK_INTERP_END)
}

test("interp: expr with identifier") {
    val src = mkExprSrc("", "name", "")
    val lex = newLexer(src)
    lexReadString(lex)
    // INTERP_START, EXPR_START, ID(name), EXPR_END, INTERP_END
    assertEqual(lex.tokens.size(), 5)
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[3].kind, TK_ID)
    assertEqual(lex.tokens[3].value, "name")
    assertEqual(lex.tokens[4].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[5].kind, TK_INTERP_END)
}

test("interp: text before and after expr") {
    val src = mkExprSrc("a", "1", "b")
    val lex = newLexer(src)
    lexReadString(lex)
    // INTERP_START, TEXT(a), EXPR_START, INT(1), EXPR_END, TEXT(b), INTERP_END
    assertEqual(lex.tokens.size(), 7)
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_TEXT)
    assertEqual(lex.tokens[2].value, "a")
    assertEqual(lex.tokens[3].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[4].kind, TK_INT)
    assertEqual(lex.tokens[4].value, "1")
    assertEqual(lex.tokens[5].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[6].kind, TK_INTERP_TEXT)
    assertEqual(lex.tokens[6].value, "b")
    assertEqual(lex.tokens[7].kind, TK_INTERP_END)
}

// === Nested braces in expr ===

test("interp: nested braces in expr") {
    // "${a + {x: 1}.y}"
    val src = mkExprSrc("", "a + {x: 1}.y", "")
    val lex = newLexer(src)
    lexReadString(lex)
    // INTERP_START, EXPR_START, ID(a), PLUS, LBRACE, ID(x), COLON, INT(1), RBRACE, DOT, ID(y), EXPR_END, INTERP_END
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[3].kind, TK_ID)
    assertEqual(lex.tokens[3].value, "a")
    assertEqual(lex.tokens[4].kind, TK_PLUS)
    assertEqual(lex.tokens[5].kind, TK_LBRACE)
    assertEqual(lex.tokens[6].kind, TK_ID)
    assertEqual(lex.tokens[6].value, "x")
    assertEqual(lex.tokens[7].kind, TK_COLON)
    assertEqual(lex.tokens[8].kind, TK_INT)
    assertEqual(lex.tokens[8].value, "1")
    assertEqual(lex.tokens[9].kind, TK_RBRACE)
    assertEqual(lex.tokens[10].kind, TK_DOT)
    assertEqual(lex.tokens[11].kind, TK_ID)
    assertEqual(lex.tokens[11].value, "y")
    assertEqual(lex.tokens[12].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[13].kind, TK_INTERP_END)
}

// === Escaped dollar prevents interpolation ===

test("escaped dollar: no interpolation") {
    // Source: "hello\$name" - escaped dollar, no interpolation
    val src: string = luaExpr("'\"hello\\\\' .. string.char(36) .. 'name\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    assertEqual(lex.tokens.size(), 1)
    assertEqual(lex.tokens[1].kind, TK_STRING)
    val expected: string = luaExpr("'hello' .. string.char(36) .. 'name'")
    assertEqual(lex.tokens[1].value, expected)
}

// === Dollar at end of string (not followed by ident or brace) ===

test("interp: dollar at end of string") {
    // "hello$" - dollar at the end before closing quote
    val src: string = luaExpr("'\"hello' .. string.char(36) .. '\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    // Has dollar so enters interpolation mode
    // INTERP_START, TEXT("hello"), TEXT(dollar as literal), INTERP_END
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_TEXT)
    assertEqual(lex.tokens[2].value, "hello")
    assertEqual(lex.tokens[3].kind, TK_INTERP_TEXT)
    val dollarStr = dollar()
    assertEqual(lex.tokens[3].value, dollarStr)
    assertEqual(lex.tokens[4].kind, TK_INTERP_END)
}

// === Only interpolation, no literal text ===

test("interp: only identifier, no text") {
    val src = mkInterpSrc("", "name", "")
    val lex = newLexer(src)
    lexReadString(lex)
    // INTERP_START, EXPR_START, ID(name), EXPR_END, INTERP_END
    assertEqual(lex.tokens.size(), 5)
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[3].kind, TK_ID)
    assertEqual(lex.tokens[3].value, "name")
    assertEqual(lex.tokens[4].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[5].kind, TK_INTERP_END)
}

test("interp: identifier with underscore and digits") {
    val src = mkInterpSrc("", "my_var2", "")
    val lex = newLexer(src)
    lexReadString(lex)
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[3].kind, TK_ID)
    assertEqual(lex.tokens[3].value, "my_var2")
    assertEqual(lex.tokens[4].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[5].kind, TK_INTERP_END)
}

// === Mixed ident and expr interpolation ===

test("interp: mixed ident and expr") {
    // "$a=${1}"
    val src: string = luaExpr("'\"' .. string.char(36) .. 'a=' .. string.char(36) .. '{1}\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    // INTERP_START, EXPR_START, ID(a), EXPR_END, TEXT("="), EXPR_START, INT(1), EXPR_END, INTERP_END
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[3].kind, TK_ID)
    assertEqual(lex.tokens[3].value, "a")
    assertEqual(lex.tokens[4].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[5].kind, TK_INTERP_TEXT)
    assertEqual(lex.tokens[5].value, "=")
    assertEqual(lex.tokens[6].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[7].kind, TK_INT)
    assertEqual(lex.tokens[7].value, "1")
    assertEqual(lex.tokens[8].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[9].kind, TK_INTERP_END)
}

// === Escape sequences inside interpolated strings ===

test("interp: escape in text segment") {
    // "hello\n$name"
    val src: string = luaExpr("'\"hello\\\\n' .. string.char(36) .. 'name\"'")
    val lex = newLexer(src)
    lexReadString(lex)
    assertEqual(lex.tokens[1].kind, TK_INTERP_START)
    assertEqual(lex.tokens[2].kind, TK_INTERP_TEXT)
    val expectedText: string = luaExpr("'hello\\n'")
    assertEqual(lex.tokens[2].value, expectedText)
    assertEqual(lex.tokens[3].kind, TK_INTERP_EXPR_START)
    assertEqual(lex.tokens[4].kind, TK_ID)
    assertEqual(lex.tokens[4].value, "name")
    assertEqual(lex.tokens[5].kind, TK_INTERP_EXPR_END)
    assertEqual(lex.tokens[6].kind, TK_INTERP_END)
}

summary()
