import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/token { Token, newToken, TK_INT, TK_FLOAT, TK_STRING, TK_TRUE, TK_FALSE, TK_UNIT, TK_ID, TK_PLUS, TK_MINUS, TK_STAR, TK_SLASH, TK_PERCENT, TK_EQEQ, TK_NEQ, TK_LT, TK_LTEQ, TK_GT, TK_GTEQ, TK_NOT, TK_AND, TK_OR, TK_AMP, TK_PIPE, TK_LSHIFT, TK_RSHIFT, TK_WEAVE, TK_UNDERSCORE, TK_DOT, TK_COMMA, TK_COLON, TK_EQ, TK_PLUSEQ, TK_MINUSEQ, TK_STAREQ, TK_SLASHEQ, TK_LPAREN, TK_RPAREN, TK_LBRACE, TK_RBRACE, TK_LBRACKET, TK_RBRACKET, TK_RETURN, TK_BREAK, TK_CONTINUE, TK_EOF, TK_NEWLINE, TK_FN, TK_VAL, TK_VAR, TK_PUB, TK_ARROW, TK_IF, TK_ELSE, TK_WHILE, TK_FOR, TK_IN, TK_WHEN }
import chicc/parser { newParser, parseExpression, parseExpr }
import chicc/parse_ast { ParseAst }
import std/lang { luaExpr }

fn tk(kind: int, value: string): Token { newToken(kind, value, unit) }
fn eof(): Token { newToken(TK_EOF, "", unit) }

// ==============================
// parseIfElse tests
// ==============================

test("parse if without else") {
    // if true { 1 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_TRUE, "true"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseIfElse")
    assertEqual(paTag(result.paCondition()), "BoolValue")
    assertTrue(paBoolValue(result.paCondition()))
    val thenB = result.paThenBody()
    assertEqual(thenB.paTag(), "ParseBlock")
    assertEqual(thenB.paBody().size(), 1)
    assertTrue(result.paElseBody() == unit)
}

test("parse if with else") {
    // if true { 1 } else { 2 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_TRUE, "true"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        tk(TK_ELSE, "else"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "2"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseIfElse")
    val thenB = result.paThenBody()
    assertEqual(thenB.paTag(), "ParseBlock")
    assertEqual(thenB.paBody().size(), 1)
    val elseB = result.paElseBody()
    assertTrue(elseB != unit)
    assertEqual(elseB.paTag(), "ParseBlock")
    assertEqual(elseB.paBody().size(), 1)
}

test("parse if with else if") {
    // if x { 1 } else if y { 2 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_ID, "x"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        tk(TK_ELSE, "else"),
        tk(TK_IF, "if"), tk(TK_ID, "y"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "2"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseIfElse")
    assertEqual(paVariableName(result.paCondition()), "x")
    val elseB = result.paElseBody()
    assertTrue(elseB != unit)
    // else if produces a nested ParseIfElse
    assertEqual(elseB.paTag(), "ParseIfElse")
    assertEqual(paVariableName(elseB.paCondition()), "y")
}

test("parse if else if else") {
    // if a { 1 } else if b { 2 } else { 3 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_ID, "a"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        tk(TK_ELSE, "else"),
        tk(TK_IF, "if"), tk(TK_ID, "b"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "2"), tk(TK_RBRACE, "}"),
        tk(TK_ELSE, "else"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "3"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseIfElse")
    assertEqual(paVariableName(result.paCondition()), "a")
    val elseIfNode = result.paElseBody()
    assertEqual(elseIfNode.paTag(), "ParseIfElse")
    assertEqual(paVariableName(elseIfNode.paCondition()), "b")
    val finalElse = elseIfNode.paElseBody()
    assertEqual(finalElse.paTag(), "ParseBlock")
    assertEqual(finalElse.paBody().size(), 1)
}

test("parse if with expression condition") {
    // if x > 0 { 1 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_ID, "x"), tk(TK_GT, ">"), tk(TK_INT, "0"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseIfElse")
    val cond = result.paCondition()
    assertEqual(cond.paTag(), "ParseBinaryOp")
    assertEqual(cond.paOp(), ">")
}

test("parse if with newlines before else") {
    // if true { 1 } \n else { 2 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_TRUE, "true"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_ELSE, "else"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "2"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseIfElse")
    val elseB = result.paElseBody()
    assertTrue(elseB != unit)
    assertEqual(elseB.paTag(), "ParseBlock")
}

// ==============================
// parseWhile tests
// ==============================

test("parse while loop basic") {
    // while true { 1 }
    val tokens = [
        tk(TK_WHILE, "while"), tk(TK_TRUE, "true"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseWhile")
    assertEqual(paTag(result.paCondition()), "BoolValue")
    assertTrue(paBoolValue(result.paCondition()))
    val body = result.paLoopBody()
    assertEqual(body.paTag(), "ParseBlock")
    assertEqual(body.paBody().size(), 1)
}

test("parse while with expression condition") {
    // while x < 10 { x }
    val tokens = [
        tk(TK_WHILE, "while"), tk(TK_ID, "x"), tk(TK_LT, "<"), tk(TK_INT, "10"),
        tk(TK_LBRACE, "{"), tk(TK_ID, "x"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseWhile")
    val cond = result.paCondition()
    assertEqual(cond.paTag(), "ParseBinaryOp")
    assertEqual(cond.paOp(), "<")
}

test("parse while with multi-line body") {
    // while true { 1 \n 2 \n 3 }
    val tokens = [
        tk(TK_WHILE, "while"), tk(TK_TRUE, "true"),
        tk(TK_LBRACE, "{"),
        tk(TK_INT, "1"), tk(TK_NEWLINE, "\n"),
        tk(TK_INT, "2"), tk(TK_NEWLINE, "\n"),
        tk(TK_INT, "3"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseWhile")
    val body = result.paLoopBody()
    assertEqual(body.paTag(), "ParseBlock")
    assertEqual(body.paBody().size(), 3)
}

// ==============================
// parseFor tests
// ==============================

test("parse for with single var") {
    // for x in arr { x }
    val tokens = [
        tk(TK_FOR, "for"), tk(TK_ID, "x"), tk(TK_IN, "in"), tk(TK_ID, "arr"),
        tk(TK_LBRACE, "{"), tk(TK_ID, "x"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseFor")
    assertEqual(result.paForVars().size(), 1)
    assertEqual(result.paForVars()[1], "x")
    assertEqual(paVariableName(result.paIterable()), "arr")
    assertTrue(result.paForState() == unit)
    assertTrue(result.paForInit() == unit)
    val body = result.paForBody()
    assertEqual(body.paTag(), "ParseBlock")
    assertEqual(body.paBody().size(), 1)
}

test("parse for with two vars") {
    // for idx, val in arr { 1 }
    val tokens = [
        tk(TK_FOR, "for"), tk(TK_ID, "idx"), tk(TK_COMMA, ","), tk(TK_ID, "item"),
        tk(TK_IN, "in"), tk(TK_ID, "arr"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseFor")
    assertEqual(result.paForVars().size(), 2)
    assertEqual(result.paForVars()[1], "idx")
    assertEqual(result.paForVars()[2], "item")
}

test("parse for with state and init") {
    // for x in gen, state, init { x }
    val tokens = [
        tk(TK_FOR, "for"), tk(TK_ID, "x"), tk(TK_IN, "in"),
        tk(TK_ID, "gen"), tk(TK_COMMA, ","),
        tk(TK_ID, "state"), tk(TK_COMMA, ","),
        tk(TK_ID, "initVal"),
        tk(TK_LBRACE, "{"), tk(TK_ID, "x"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseFor")
    assertEqual(result.paForVars().size(), 1)
    assertEqual(result.paForVars()[1], "x")
    assertEqual(paVariableName(result.paIterable()), "gen")
    assertTrue(result.paForState() != unit)
    assertEqual(paVariableName(result.paForState()), "state")
    assertTrue(result.paForInit() != unit)
    assertEqual(paVariableName(result.paForInit()), "initVal")
}

test("parse for with multi-line body") {
    // for x in arr { 1 \n 2 }
    val tokens = [
        tk(TK_FOR, "for"), tk(TK_ID, "x"), tk(TK_IN, "in"), tk(TK_ID, "arr"),
        tk(TK_LBRACE, "{"),
        tk(TK_INT, "1"), tk(TK_NEWLINE, "\n"),
        tk(TK_INT, "2"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseFor")
    val body = result.paForBody()
    assertEqual(body.paTag(), "ParseBlock")
    assertEqual(body.paBody().size(), 2)
}

// ==============================
// parseWhen tests
// ==============================

test("parse when with single case") {
    // when { true -> 1 }
    val tokens = [
        tk(TK_WHEN, "when"),
        tk(TK_LBRACE, "{"),
        tk(TK_TRUE, "true"), tk(TK_ARROW, "->"), tk(TK_INT, "1"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseWhen")
    assertEqual(result.paWhenCases().size(), 1)
    val c1 = result.paWhenCases()[1]
    assertEqual(paTag(c1.condition), "BoolValue")
    assertTrue(paBoolValue(c1.condition))
    assertEqual(paLongValue(c1.body), 1)
    assertTrue(result.paElseCase() == unit)
}

test("parse when with multiple cases") {
    // when { x > 0 -> 1 \n x < 0 -> 2 }
    val tokens = [
        tk(TK_WHEN, "when"),
        tk(TK_LBRACE, "{"),
        tk(TK_ID, "x"), tk(TK_GT, ">"), tk(TK_INT, "0"), tk(TK_ARROW, "->"), tk(TK_INT, "1"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_ID, "x"), tk(TK_LT, "<"), tk(TK_INT, "0"), tk(TK_ARROW, "->"), tk(TK_INT, "2"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseWhen")
    assertEqual(result.paWhenCases().size(), 2)
    val c1 = result.paWhenCases()[1]
    assertEqual(paTag(c1.condition), "ParseBinaryOp")
    assertEqual(paOp(c1.condition), ">")
    val c2 = result.paWhenCases()[2]
    assertEqual(paTag(c2.condition), "ParseBinaryOp")
    assertEqual(paOp(c2.condition), "<")
}

test("parse when with else case") {
    // when { true -> 1 \n else -> 0 }
    val tokens = [
        tk(TK_WHEN, "when"),
        tk(TK_LBRACE, "{"),
        tk(TK_TRUE, "true"), tk(TK_ARROW, "->"), tk(TK_INT, "1"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_ELSE, "else"), tk(TK_ARROW, "->"), tk(TK_INT, "0"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseWhen")
    assertEqual(result.paWhenCases().size(), 1)
    val ec = result.paElseCase()
    assertTrue(ec != unit)
    assertEqual(paLongValue(ec.body), 0)
}

test("parse when with cases and else") {
    // when { x == 1 -> 10 \n x == 2 -> 20 \n else -> 30 }
    val tokens = [
        tk(TK_WHEN, "when"),
        tk(TK_LBRACE, "{"),
        tk(TK_ID, "x"), tk(TK_EQEQ, "=="), tk(TK_INT, "1"), tk(TK_ARROW, "->"), tk(TK_INT, "10"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_ID, "x"), tk(TK_EQEQ, "=="), tk(TK_INT, "2"), tk(TK_ARROW, "->"), tk(TK_INT, "20"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_ELSE, "else"), tk(TK_ARROW, "->"), tk(TK_INT, "30"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseWhen")
    assertEqual(result.paWhenCases().size(), 2)
    val ec = result.paElseCase()
    assertTrue(ec != unit)
    assertEqual(paLongValue(ec.body), 30)
}

test("parse when with newlines") {
    // when { \n true -> 1 \n }
    val tokens = [
        tk(TK_WHEN, "when"),
        tk(TK_LBRACE, "{"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_TRUE, "true"), tk(TK_ARROW, "->"), tk(TK_INT, "1"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(result.paTag(), "ParseWhen")
    assertEqual(result.paWhenCases().size(), 1)
}

summary()
