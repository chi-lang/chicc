import user/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import user/token { Token, newToken, TK_INT, TK_FLOAT, TK_STRING, TK_TRUE, TK_FALSE, TK_UNIT, TK_ID, TK_PLUS, TK_MINUS, TK_STAR, TK_SLASH, TK_PERCENT, TK_EQEQ, TK_NEQ, TK_LT, TK_LTEQ, TK_GT, TK_GTEQ, TK_NOT, TK_AND, TK_OR, TK_AMP, TK_PIPE, TK_LSHIFT, TK_RSHIFT, TK_WEAVE, TK_UNDERSCORE, TK_DOT, TK_COMMA, TK_COLON, TK_EQ, TK_PLUSEQ, TK_MINUSEQ, TK_STAREQ, TK_SLASHEQ, TK_LPAREN, TK_RPAREN, TK_LBRACE, TK_RBRACE, TK_LBRACKET, TK_RBRACKET, TK_RETURN, TK_BREAK, TK_CONTINUE, TK_EOF, TK_NEWLINE, TK_FN, TK_VAL, TK_VAR, TK_PUB, TK_ARROW, TK_IF, TK_ELSE, TK_WHILE, TK_FOR, TK_IN, TK_WHEN }
import user/parser { newParser, parseExpression, parseExpr }
import user/parse_ast { paTag, paLongValue, paFloatValue, paBoolValue, paStringValue, paVariableName, paOp, paLeft, paRight, paValue, paReturnValue, paArrayValues, paRecordFields, paCallee, paArguments, paReceiverName, paMemberName, paReceiver, paVariable, paIndexExpr, paIndexValue, paCondition, paThenBody, paElseBody, paLoopBody, paForVars, paIterable, paForState, paForInit, paForBody, paWhenCases, paElseCase, paBody }
import std/lang.array { size }
import std/lang { luaExpr }

fn tk(kind: int, value: string): Token { newToken(kind, value, unit) }
fn eof(): Token { newToken(TK_EOF, "", unit) }

// ==============================
// parseIfElse tests
// ==============================

test("parse if without else") {
    // if true { 1 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_TRUE, "true"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseIfElse")
    assertEqual(paTag(paCondition(result)), "BoolValue")
    assertTrue(paBoolValue(paCondition(result)))
    val thenB = paThenBody(result)
    assertEqual(paTag(thenB), "ParseBlock")
    assertEqual(paBody(thenB).size(), 1)
    assertTrue(paElseBody(result) == unit)
}

test("parse if with else") {
    // if true { 1 } else { 2 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_TRUE, "true"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        tk(TK_ELSE, "else"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "2"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseIfElse")
    val thenB = paThenBody(result)
    assertEqual(paTag(thenB), "ParseBlock")
    assertEqual(paBody(thenB).size(), 1)
    val elseB = paElseBody(result)
    assertTrue(elseB != unit)
    assertEqual(paTag(elseB), "ParseBlock")
    assertEqual(paBody(elseB).size(), 1)
}

test("parse if with else if") {
    // if x { 1 } else if y { 2 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_ID, "x"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        tk(TK_ELSE, "else"),
        tk(TK_IF, "if"), tk(TK_ID, "y"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "2"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseIfElse")
    assertEqual(paVariableName(paCondition(result)), "x")
    val elseB = paElseBody(result)
    assertTrue(elseB != unit)
    // else if produces a nested ParseIfElse
    assertEqual(paTag(elseB), "ParseIfElse")
    assertEqual(paVariableName(paCondition(elseB)), "y")
}

test("parse if else if else") {
    // if a { 1 } else if b { 2 } else { 3 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_ID, "a"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        tk(TK_ELSE, "else"),
        tk(TK_IF, "if"), tk(TK_ID, "b"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "2"), tk(TK_RBRACE, "}"),
        tk(TK_ELSE, "else"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "3"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseIfElse")
    assertEqual(paVariableName(paCondition(result)), "a")
    val elseIfNode = paElseBody(result)
    assertEqual(paTag(elseIfNode), "ParseIfElse")
    assertEqual(paVariableName(paCondition(elseIfNode)), "b")
    val finalElse = paElseBody(elseIfNode)
    assertEqual(paTag(finalElse), "ParseBlock")
    assertEqual(paBody(finalElse).size(), 1)
}

test("parse if with expression condition") {
    // if x > 0 { 1 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_ID, "x"), tk(TK_GT, ">"), tk(TK_INT, "0"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseIfElse")
    val cond = paCondition(result)
    assertEqual(paTag(cond), "ParseBinaryOp")
    assertEqual(paOp(cond), ">")
}

test("parse if with newlines before else") {
    // if true { 1 } \n else { 2 }
    val tokens = [
        tk(TK_IF, "if"), tk(TK_TRUE, "true"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_ELSE, "else"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "2"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseIfElse")
    val elseB = paElseBody(result)
    assertTrue(elseB != unit)
    assertEqual(paTag(elseB), "ParseBlock")
}

// ==============================
// parseWhile tests
// ==============================

test("parse while loop basic") {
    // while true { 1 }
    val tokens = [
        tk(TK_WHILE, "while"), tk(TK_TRUE, "true"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseWhile")
    assertEqual(paTag(paCondition(result)), "BoolValue")
    assertTrue(paBoolValue(paCondition(result)))
    val body = paLoopBody(result)
    assertEqual(paTag(body), "ParseBlock")
    assertEqual(paBody(body).size(), 1)
}

test("parse while with expression condition") {
    // while x < 10 { x }
    val tokens = [
        tk(TK_WHILE, "while"), tk(TK_ID, "x"), tk(TK_LT, "<"), tk(TK_INT, "10"),
        tk(TK_LBRACE, "{"), tk(TK_ID, "x"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseWhile")
    val cond = paCondition(result)
    assertEqual(paTag(cond), "ParseBinaryOp")
    assertEqual(paOp(cond), "<")
}

test("parse while with multi-line body") {
    // while true { 1 \n 2 \n 3 }
    val tokens = [
        tk(TK_WHILE, "while"), tk(TK_TRUE, "true"),
        tk(TK_LBRACE, "{"),
        tk(TK_INT, "1"), tk(TK_NEWLINE, "\n"),
        tk(TK_INT, "2"), tk(TK_NEWLINE, "\n"),
        tk(TK_INT, "3"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseWhile")
    val body = paLoopBody(result)
    assertEqual(paTag(body), "ParseBlock")
    assertEqual(paBody(body).size(), 3)
}

// ==============================
// parseFor tests
// ==============================

test("parse for with single var") {
    // for x in arr { x }
    val tokens = [
        tk(TK_FOR, "for"), tk(TK_ID, "x"), tk(TK_IN, "in"), tk(TK_ID, "arr"),
        tk(TK_LBRACE, "{"), tk(TK_ID, "x"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseFor")
    assertEqual(paForVars(result).size(), 1)
    assertEqual(paForVars(result)[1], "x")
    assertEqual(paVariableName(paIterable(result)), "arr")
    assertTrue(paForState(result) == unit)
    assertTrue(paForInit(result) == unit)
    val body = paForBody(result)
    assertEqual(paTag(body), "ParseBlock")
    assertEqual(paBody(body).size(), 1)
}

test("parse for with two vars") {
    // for idx, val in arr { 1 }
    val tokens = [
        tk(TK_FOR, "for"), tk(TK_ID, "idx"), tk(TK_COMMA, ","), tk(TK_ID, "item"),
        tk(TK_IN, "in"), tk(TK_ID, "arr"),
        tk(TK_LBRACE, "{"), tk(TK_INT, "1"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseFor")
    assertEqual(paForVars(result).size(), 2)
    assertEqual(paForVars(result)[1], "idx")
    assertEqual(paForVars(result)[2], "item")
}

test("parse for with state and init") {
    // for x in gen, state, init { x }
    val tokens = [
        tk(TK_FOR, "for"), tk(TK_ID, "x"), tk(TK_IN, "in"),
        tk(TK_ID, "gen"), tk(TK_COMMA, ","),
        tk(TK_ID, "state"), tk(TK_COMMA, ","),
        tk(TK_ID, "initVal"),
        tk(TK_LBRACE, "{"), tk(TK_ID, "x"), tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseFor")
    assertEqual(paForVars(result).size(), 1)
    assertEqual(paForVars(result)[1], "x")
    assertEqual(paVariableName(paIterable(result)), "gen")
    assertTrue(paForState(result) != unit)
    assertEqual(paVariableName(paForState(result)), "state")
    assertTrue(paForInit(result) != unit)
    assertEqual(paVariableName(paForInit(result)), "initVal")
}

test("parse for with multi-line body") {
    // for x in arr { 1 \n 2 }
    val tokens = [
        tk(TK_FOR, "for"), tk(TK_ID, "x"), tk(TK_IN, "in"), tk(TK_ID, "arr"),
        tk(TK_LBRACE, "{"),
        tk(TK_INT, "1"), tk(TK_NEWLINE, "\n"),
        tk(TK_INT, "2"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseFor")
    val body = paForBody(result)
    assertEqual(paTag(body), "ParseBlock")
    assertEqual(paBody(body).size(), 2)
}

// ==============================
// parseWhen tests
// ==============================

test("parse when with single case") {
    // when { true -> 1 }
    val tokens = [
        tk(TK_WHEN, "when"),
        tk(TK_LBRACE, "{"),
        tk(TK_TRUE, "true"), tk(TK_ARROW, "->"), tk(TK_INT, "1"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseWhen")
    assertEqual(paWhenCases(result).size(), 1)
    val c1 = paWhenCases(result)[1]
    assertEqual(paTag(c1.condition), "BoolValue")
    assertTrue(paBoolValue(c1.condition))
    assertEqual(paLongValue(c1.body), 1)
    assertTrue(paElseCase(result) == unit)
}

test("parse when with multiple cases") {
    // when { x > 0 -> 1 \n x < 0 -> 2 }
    val tokens = [
        tk(TK_WHEN, "when"),
        tk(TK_LBRACE, "{"),
        tk(TK_ID, "x"), tk(TK_GT, ">"), tk(TK_INT, "0"), tk(TK_ARROW, "->"), tk(TK_INT, "1"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_ID, "x"), tk(TK_LT, "<"), tk(TK_INT, "0"), tk(TK_ARROW, "->"), tk(TK_INT, "2"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseWhen")
    assertEqual(paWhenCases(result).size(), 2)
    val c1 = paWhenCases(result)[1]
    assertEqual(paTag(c1.condition), "ParseBinaryOp")
    assertEqual(paOp(c1.condition), ">")
    val c2 = paWhenCases(result)[2]
    assertEqual(paTag(c2.condition), "ParseBinaryOp")
    assertEqual(paOp(c2.condition), "<")
}

test("parse when with else case") {
    // when { true -> 1 \n else -> 0 }
    val tokens = [
        tk(TK_WHEN, "when"),
        tk(TK_LBRACE, "{"),
        tk(TK_TRUE, "true"), tk(TK_ARROW, "->"), tk(TK_INT, "1"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_ELSE, "else"), tk(TK_ARROW, "->"), tk(TK_INT, "0"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseWhen")
    assertEqual(paWhenCases(result).size(), 1)
    val ec = paElseCase(result)
    assertTrue(ec != unit)
    assertEqual(paLongValue(ec.body), 0)
}

test("parse when with cases and else") {
    // when { x == 1 -> 10 \n x == 2 -> 20 \n else -> 30 }
    val tokens = [
        tk(TK_WHEN, "when"),
        tk(TK_LBRACE, "{"),
        tk(TK_ID, "x"), tk(TK_EQEQ, "=="), tk(TK_INT, "1"), tk(TK_ARROW, "->"), tk(TK_INT, "10"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_ID, "x"), tk(TK_EQEQ, "=="), tk(TK_INT, "2"), tk(TK_ARROW, "->"), tk(TK_INT, "20"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_ELSE, "else"), tk(TK_ARROW, "->"), tk(TK_INT, "30"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseWhen")
    assertEqual(paWhenCases(result).size(), 2)
    val ec = paElseCase(result)
    assertTrue(ec != unit)
    assertEqual(paLongValue(ec.body), 30)
}

test("parse when with newlines") {
    // when { \n true -> 1 \n }
    val tokens = [
        tk(TK_WHEN, "when"),
        tk(TK_LBRACE, "{"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_TRUE, "true"), tk(TK_ARROW, "->"), tk(TK_INT, "1"),
        tk(TK_NEWLINE, "\n"),
        tk(TK_RBRACE, "}"),
        eof()
    ]
    val p = newParser(tokens, "")
    val result = parseExpression(p)
    assertEqual(paTag(result), "ParseWhen")
    assertEqual(paWhenCases(result).size(), 1)
}

summary()
