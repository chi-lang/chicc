import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/lexer { tokenize }
import chicc/token { TK_EOF }
import chicc/parser { newParser, parseTypeRefImpl, parseTypeAliasImpl, parseVariantTypeDef, peek }
import chicc/parse_ast { TypeRef }
import std/lang { luaExpr }

// Helper to get field name from TypeRefField
fn trfName(f: any): string { luaExpr("f.name") }
fn trfTypeRef(f: any): any { luaExpr("f.typeRef") }

// === parseTypeRefImpl tests ===

// -- Simple type names --

test("parseTypeRef - simple type name") {
    val src = "int\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "TypeNameRef")
    assertEqual((tr as TypeRef).name, "int")
    assertEqual((tr as TypeRef).moduleName, "")
    assertEqual((tr as TypeRef).packageName, "")
}

test("parseTypeRef - string type") {
    val src = "string\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "TypeNameRef")
    assertEqual((tr as TypeRef).name, "string")
}

test("parseTypeRef - bool type") {
    val src = "bool\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "TypeNameRef")
    assertEqual((tr as TypeRef).name, "bool")
}

test("parseTypeRef - custom type name") {
    val src = "MyType\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "TypeNameRef")
    assertEqual((tr as TypeRef).name, "MyType")
}

// -- unit type --

test("parseTypeRef - unit") {
    val src = "unit\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "TypeNameRef")
    assertEqual((tr as TypeRef).name, "unit")
}

// -- Generic types --

test("parseTypeRef - generic single param") {
    val src = "array[int]\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "TypeConstructorRef")
    val base = (tr as TypeRef).baseType
    assertEqual((base as TypeRef).tag, "TypeNameRef")
    assertEqual((base as TypeRef).name, "array")
    val tps = (tr as TypeRef).typeParameters
    assertEqual(tps.size(), 1)
    assertEqual((tps[1] as TypeRef).tag, "TypeNameRef")
    assertEqual((tps[1] as TypeRef).name, "int")
}

test("parseTypeRef - generic multiple params") {
    val src = "Map[string, int]\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "TypeConstructorRef")
    val base = (tr as TypeRef).baseType
    assertEqual((base as TypeRef).name, "Map")
    val tps = (tr as TypeRef).typeParameters
    assertEqual(tps.size(), 2)
    assertEqual((tps[1] as TypeRef).name, "string")
    assertEqual((tps[2] as TypeRef).name, "int")
}

test("parseTypeRef - nested generic") {
    val src = "array[array[int]]\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "TypeConstructorRef")
    assertEqual(((tr as TypeRef).baseType as TypeRef).name, "array")
    val inner = (tr as TypeRef).typeParameters[1]
    assertEqual((inner as TypeRef).tag, "TypeConstructorRef")
    assertEqual(((inner as TypeRef).baseType as TypeRef).name, "array")
    val innerParam = (inner as TypeRef).typeParameters[1]
    assertEqual((innerParam as TypeRef).name, "int")
}

// -- Function types --

test("parseTypeRef - function type no args") {
    val src = "() -> int\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "FunctionTypeRef")
    assertEqual((tr as TypeRef).argumentTypeRefs.size(), 0)
    assertEqual(((tr as TypeRef).returnType as TypeRef).tag, "TypeNameRef")
    assertEqual(((tr as TypeRef).returnType as TypeRef).name, "int")
}

test("parseTypeRef - function type single arg") {
    val src = "(int) -> string\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "FunctionTypeRef")
    val args = (tr as TypeRef).argumentTypeRefs
    assertEqual(args.size(), 1)
    assertEqual((args[1] as TypeRef).name, "int")
    assertEqual(((tr as TypeRef).returnType as TypeRef).name, "string")
}

test("parseTypeRef - function type multiple args") {
    val src = "(int, string) -> bool\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "FunctionTypeRef")
    val args = (tr as TypeRef).argumentTypeRefs
    assertEqual(args.size(), 2)
    assertEqual((args[1] as TypeRef).name, "int")
    assertEqual((args[2] as TypeRef).name, "string")
    assertEqual(((tr as TypeRef).returnType as TypeRef).name, "bool")
}

test("parseTypeRef - function type unit return") {
    val src = "(int) -> unit\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "FunctionTypeRef")
    assertEqual(((tr as TypeRef).returnType as TypeRef).name, "unit")
}

// -- Record types --

test("parseTypeRef - record type single field") {
    val src = "{ name: string }\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "RecordTypeRef")
    val fields = (tr as TypeRef).fields
    assertEqual(fields.size(), 1)
    assertEqual(trfName(fields[1]), "name")
    assertEqual((trfTypeRef(fields[1]) as TypeRef).name, "string")
}

test("parseTypeRef - record type multiple fields") {
    val src = "{ name: string, age: int }\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "RecordTypeRef")
    val fields = (tr as TypeRef).fields
    assertEqual(fields.size(), 2)
    assertEqual(trfName(fields[1]), "name")
    assertEqual((trfTypeRef(fields[1]) as TypeRef).name, "string")
    assertEqual(trfName(fields[2]), "age")
    assertEqual((trfTypeRef(fields[2]) as TypeRef).name, "int")
}

// -- Sum types --

test("parseTypeRef - sum type two options") {
    val src = "int | string\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "SumTypeRef")
    assertEqual(((tr as TypeRef).lhs as TypeRef).name, "int")
    assertEqual(((tr as TypeRef).rhs as TypeRef).name, "string")
}

test("parseTypeRef - sum type three options") {
    val src = "int | string | bool\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    // Should be left-associative: (int | string) | bool
    assertEqual((tr as TypeRef).tag, "SumTypeRef")
    assertEqual(((tr as TypeRef).lhs as TypeRef).tag, "SumTypeRef")
    assertEqual(((tr as TypeRef).rhs as TypeRef).name, "bool")
    val inner = (tr as TypeRef).lhs
    assertEqual(((inner as TypeRef).lhs as TypeRef).name, "int")
    assertEqual(((inner as TypeRef).rhs as TypeRef).name, "string")
}

test("parseTypeRef - sum with unit") {
    val src = "int | unit\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "SumTypeRef")
    assertEqual(((tr as TypeRef).lhs as TypeRef).name, "int")
    assertEqual(((tr as TypeRef).rhs as TypeRef).name, "unit")
}

// -- Complex/nested types --

test("parseTypeRef - generic with sum type param") {
    val src = "array[int | string]\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "TypeConstructorRef")
    assertEqual(((tr as TypeRef).baseType as TypeRef).name, "array")
    val param = (tr as TypeRef).typeParameters[1]
    assertEqual((param as TypeRef).tag, "SumTypeRef")
    assertEqual(((param as TypeRef).lhs as TypeRef).name, "int")
    assertEqual(((param as TypeRef).rhs as TypeRef).name, "string")
}

test("parseTypeRef - function type with generic args") {
    val src = "(array[int]) -> string\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "FunctionTypeRef")
    val args = (tr as TypeRef).argumentTypeRefs
    assertEqual(args.size(), 1)
    assertEqual((args[1] as TypeRef).tag, "TypeConstructorRef")
    assertEqual(((args[1] as TypeRef).baseType as TypeRef).name, "array")
}

test("parseTypeRef - record type with generic field") {
    val src = "{ items: array[int], name: string }\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val tr = parseTypeRefImpl(p)
    assertEqual((tr as TypeRef).tag, "RecordTypeRef")
    val fields = (tr as TypeRef).fields
    assertEqual(fields.size(), 2)
    assertEqual(trfName(fields[1]), "items")
    assertEqual((trfTypeRef(fields[1]) as TypeRef).tag, "TypeConstructorRef")
    assertEqual(trfName(fields[2]), "name")
    assertEqual((trfTypeRef(fields[2]) as TypeRef).name, "string")
}

// === parseTypeAliasImpl tests ===

// Helper accessors for ParseTypeAlias
fn ptaName(a: any): string { luaExpr("a.name") }
fn ptaTypeRef(a: any): any { luaExpr("a.typeRef") }
fn ptaTypeParams(a: any): array[any] { luaExpr("a.typeParameters") }

test("parseTypeAlias - simple alias") {
    val src = "type Name = string\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val alias = parseTypeAliasImpl(p)
    assertEqual(ptaName(alias), "Name")
    assertEqual((ptaTypeRef(alias) as TypeRef).tag, "TypeNameRef")
    assertEqual((ptaTypeRef(alias) as TypeRef).name, "string")
    assertEqual(ptaTypeParams(alias).size(), 0)
}

test("parseTypeAlias - record alias") {
    val src = "type Point = { x: int, y: int }\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val alias = parseTypeAliasImpl(p)
    assertEqual(ptaName(alias), "Point")
    assertEqual((ptaTypeRef(alias) as TypeRef).tag, "RecordTypeRef")
    val fields = (ptaTypeRef(alias) as TypeRef).fields
    assertEqual(fields.size(), 2)
}

test("parseTypeAlias - function type alias") {
    val src = "type Callback = (int) -> string\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val alias = parseTypeAliasImpl(p)
    assertEqual(ptaName(alias), "Callback")
    assertEqual((ptaTypeRef(alias) as TypeRef).tag, "FunctionTypeRef")
}

test("parseTypeAlias - generic alias") {
    val src = "type Option[T] = T | unit\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val alias = parseTypeAliasImpl(p)
    assertEqual(ptaName(alias), "Option")
    assertEqual(ptaTypeParams(alias).size(), 1)
    assertEqual((ptaTypeRef(alias) as TypeRef).tag, "SumTypeRef")
}

test("parseTypeAlias - multiple type params") {
    val src = "type Pair[A, B] = { first: A, second: B }\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val alias = parseTypeAliasImpl(p)
    assertEqual(ptaName(alias), "Pair")
    assertEqual(ptaTypeParams(alias).size(), 2)
    assertEqual((ptaTypeRef(alias) as TypeRef).tag, "RecordTypeRef")
}

// === parseVariantTypeDef tests ===

// Helper accessors for ParseVariantTypeDefinition
fn pvtName(v: any): string { luaExpr("v.typeName") }
fn pvtTypeParams(v: any): array[any] { luaExpr("v.typeParameters") }
fn pvtCtors(v: any): array[any] { luaExpr("v.constructors") }

// Helper accessors for VariantConstructor
fn vcIsPub(c: any): bool { luaExpr("c.isPublic") }
fn vcName(c: any): string { luaExpr("c.name") }
fn vcFields(c: any): array[any] { luaExpr("c.fields") }

// Helper accessors for FormalField
fn ffIsPub(f: any): bool { luaExpr("f.isPublic") }
fn ffName(f: any): string { luaExpr("f.name") }
fn ffTypeRef(f: any): any { luaExpr("f.typeRef") }

test("parseVariantType - simplified form") {
    val src = "data Node(value: int)\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val vt = parseVariantTypeDef(p)
    assertEqual(pvtName(vt), "Node")
    assertEqual(pvtTypeParams(vt).size(), 0)
    val ctors = pvtCtors(vt)
    assertEqual(ctors.size(), 1)
    assertEqual(vcName(ctors[1]), "Node")
    val fields = vcFields(ctors[1])
    assertEqual(fields.size(), 1)
    assertEqual(ffName(fields[1]), "value")
    assertEqual((ffTypeRef(fields[1]) as TypeRef).name, "int")
}

test("parseVariantType - simplified form with pub") {
    val src = "data pub Node(value: int)\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val vt = parseVariantTypeDef(p)
    assertEqual(pvtName(vt), "Node")
    assertTrue(vcIsPub(pvtCtors(vt)[1]))
}

test("parseVariantType - full form single ctor") {
    val src = "data Shape = Circle(radius: float)\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val vt = parseVariantTypeDef(p)
    assertEqual(pvtName(vt), "Shape")
    val ctors = pvtCtors(vt)
    assertEqual(ctors.size(), 1)
    assertEqual(vcName(ctors[1]), "Circle")
    assertEqual(ffName(vcFields(ctors[1])[1]), "radius")
}

test("parseVariantType - full form multiple ctors") {
    val src = "data Shape = Circle(radius: float) | Rectangle(width: float, height: float)\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val vt = parseVariantTypeDef(p)
    assertEqual(pvtName(vt), "Shape")
    val ctors = pvtCtors(vt)
    assertEqual(ctors.size(), 2)
    assertEqual(vcName(ctors[1]), "Circle")
    assertEqual(vcFields(ctors[1]).size(), 1)
    assertEqual(vcName(ctors[2]), "Rectangle")
    assertEqual(vcFields(ctors[2]).size(), 2)
    assertEqual(ffName(vcFields(ctors[2])[1]), "width")
    assertEqual(ffName(vcFields(ctors[2])[2]), "height")
}

test("parseVariantType - with type params") {
    val src = "data Option[T] = Some(value: T) | None\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val vt = parseVariantTypeDef(p)
    assertEqual(pvtName(vt), "Option")
    assertEqual(pvtTypeParams(vt).size(), 1)
    val ctors = pvtCtors(vt)
    assertEqual(ctors.size(), 2)
    assertEqual(vcName(ctors[1]), "Some")
    assertEqual(vcFields(ctors[1]).size(), 1)
    assertEqual(vcName(ctors[2]), "None")
    assertEqual(vcFields(ctors[2]).size(), 0)
}

test("parseVariantType - pub constructors") {
    val src = "data Result = pub Ok(value: int) | pub Err(msg: string)\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val vt = parseVariantTypeDef(p)
    assertEqual(pvtName(vt), "Result")
    val ctors = pvtCtors(vt)
    assertEqual(ctors.size(), 2)
    assertTrue(vcIsPub(ctors[1]))
    assertEqual(vcName(ctors[1]), "Ok")
    assertTrue(vcIsPub(ctors[2]))
    assertEqual(vcName(ctors[2]), "Err")
}

test("parseVariantType - simplified form multiple fields") {
    val src = "data Pair(first: int, second: string)\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val vt = parseVariantTypeDef(p)
    assertEqual(pvtName(vt), "Pair")
    val ctors = pvtCtors(vt)
    assertEqual(ctors.size(), 1)
    val fields = vcFields(ctors[1])
    assertEqual(fields.size(), 2)
    assertEqual(ffName(fields[1]), "first")
    assertEqual(ffName(fields[2]), "second")
}

test("parseVariantType - ctor with complex field types") {
    val src = "data Container[T] = Box(items: array[T], name: string)\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val vt = parseVariantTypeDef(p)
    assertEqual(pvtName(vt), "Container")
    assertEqual(pvtTypeParams(vt).size(), 1)
    val fields = vcFields(pvtCtors(vt)[1])
    assertEqual(fields.size(), 2)
    assertEqual(ffName(fields[1]), "items")
    assertEqual((ffTypeRef(fields[1]) as TypeRef).tag, "TypeConstructorRef")
    assertEqual(ffName(fields[2]), "name")
    assertEqual((ffTypeRef(fields[2]) as TypeRef).name, "string")
}

// === Integration: parseProgram with type aliases and variant types ===

test("parseProgram with type alias") {
    val src = "package user/test\ntype Name = string\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val prog = parseProgram(p)
    assertEqual(prog.typeAliases.size(), 1)
    assertEqual(ptaName(prog.typeAliases[1]), "Name")
}

test("parseProgram with variant type") {
    val src = "package user/test\ndata Shape = Circle(radius: float) | Rect(w: float, h: float)\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val prog = parseProgram(p)
    assertEqual(prog.variantTypes.size(), 1)
    assertEqual(pvtName(prog.variantTypes[1]), "Shape")
}

test("parseProgram with types and code") {
    val src = "package user/test\ntype Name = string\ndata Shape = Circle(r: float)\nval x = 1\n"
    val tokens = tokenize(src)
    val p = newParser(tokens, src)
    val prog = parseProgram(p)
    assertEqual(prog.typeAliases.size(), 1)
    assertEqual(prog.variantTypes.size(), 1)
    assertTrue(prog.code.size() > 0)
}

summary()
