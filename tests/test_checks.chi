    val messages: any = luaExpr("{}")

    val value = atomExpr("42", tInt, testSection)
    val expr = assignmentExpr(packageTarget("test", "pkg", "z"), value, testSection)
    expr.setExprType(tInt)
    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, expr)")
    immutabilityCheck(exprs, "test", "pkg", ct, unit, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 1)
}

test("immutabilityCheck: cross-module package target") {
    val ns: any = luaExpr("{}")
    embedLua("ns.getSymbol = function(mod, pkg, name) return { moduleName = mod, packageName = pkg, name = name, symbolType = nil, isPublic = true, isMutable = false } end")
    val messages: any = luaExpr("{}")

    val value = atomExpr("42", tInt, testSection)
    val expr = assignmentExpr(packageTarget("other", "otherpkg", "w"), value, testSection)
    expr.setExprType(tInt)
    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, expr)")
    immutabilityCheck(exprs, "test", "pkg", unit, ns, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 1)
}

// =========================================================================
// returnTypeCheck tests
// =========================================================================

test("returnTypeCheck: matching return type is fine") {
    val messages: any = luaExpr("{}")

    // fn: (int) -> int, body has return with int value
    val fnType = functionType([tInt, tInt], [], 0)
    val retValue = atomExpr("42", tInt, testSection)
    retValue.setExprType(tInt)
    val retExpr = returnExpr(retValue, testSection)
    retExpr.setExprType(tInt)
    val body = blockExpr([retExpr], testSection)
    body.setExprType(tInt)
    val params: any = luaExpr("{}")
    val p = newFnParam("x", tInt, testSection)
    embedLua("table.insert(params, p)")
    val fnNode = fnExpr(params, unit, body, testSection)
    fnNode.setExprType(fnType)

    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, fnNode)")
    returnTypeCheck(exprs, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 0)
}

test("returnTypeCheck: mismatched return type produces error") {
    val messages: any = luaExpr("{}")

    // fn: (int) -> int, body has return with string value
    val fnType = functionType([tInt, tInt], [], 0)
    val retValue = atomExpr("hello", tString, testSection)
    retValue.setExprType(tString)
    val retExpr = returnExpr(retValue, testSection)
    retExpr.setExprType(tString)
    val body = blockExpr([retExpr], testSection)
    body.setExprType(tString)
    val params: any = luaExpr("{}")
    val p = newFnParam("x", tInt, testSection)
    embedLua("table.insert(params, p)")
    val fnNode = fnExpr(params, unit, body, testSection)
    fnNode.setExprType(fnType)

    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, fnNode)")
    returnTypeCheck(exprs, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 1)
    val msg: any = luaExpr("messages[1]")
    val code: string = luaExpr("msg.code")
    assertEqual(code, "TYPE_MISMATCH")
}

test("returnTypeCheck: return outside function produces error") {
    val messages: any = luaExpr("{}")

    val retValue = atomExpr("42", tInt, testSection)
    retValue.setExprType(tInt)
    val retExpr = returnExpr(retValue, testSection)
    retExpr.setExprType(tInt)

    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, retExpr)")
    returnTypeCheck(exprs, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 1)
    val msg: any = luaExpr("messages[1]")
    val code: string = luaExpr("msg.code")
    assertEqual(code, "ERROR")
}

test("returnTypeCheck: name_declaration with fn value sets expected return type") {
    val messages: any = luaExpr("{}")

    // val f = fn(x: int): int { return "hello" }
    val fnType = functionType([tInt, tInt], [], 0)
    val retValue = atomExpr("hello", tString, testSection)
    retValue.setExprType(tString)
    val retExpr = returnExpr(retValue, testSection)
    retExpr.setExprType(tString)
    val body = blockExpr([retExpr], testSection)
    body.setExprType(tString)
    val params: any = luaExpr("{}")
    val p = newFnParam("x", tInt, testSection)
    embedLua("table.insert(params, p)")
    val fnNode = fnExpr(params, unit, body, testSection)
    fnNode.setExprType(fnType)

    val decl = nameDeclarationExpr(false, "f", false, unit, fnNode, testSection)
    decl.setExprType(fnType)

    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, decl)")
    returnTypeCheck(exprs, messages)
    val msgCount: int = luaExpr("#messages")
    // The return "hello" should produce a type mismatch (int vs string)
    assertEqual(msgCount, 1)
}

summary()
