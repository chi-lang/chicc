import chicc/test_util { test, assertEqual, assertTrue, assertFalse, summary }
import chicc/types { Type, tAny, tUnit, tBool, tInt, tFloat, tString, functionType }
import chicc/ast { localTarget, packageTarget, atomExpr, variableAccessExpr, fnCallExpr, nameDeclarationExpr, assignmentExpr, fnExpr, blockExpr, returnExpr, newFnParam }
import chicc/parse_ast { parseVariableRead, parseNameDeclaration, parseLambda, parseFor, parseFuncWithName, parseEffectDefinition, parseHandle, parseFnCall, parseBlock, parseBinaryOp, parseIfElse, newFormalArgument, newParseHandleCase }
import chicc/symbols { newSymbol, newCompileTables, ctDefineSymbol }
import chicc/messages { Message, unrecognizedName, cannotAccessInternalName, notAFunction, cannotChangeImmutableVariable, typeMismatch, genericError }
import chicc/source { newSection }
import std/lang { luaExpr, embedLua }

val testSection = newSection(1, 1, 1, 10)

// =========================================================================
// checkNames tests
// =========================================================================

test("checkNames: defined variable is recognized") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val messages: any = luaExpr("{}")

    // Define x, then read x
    val decl = parseNameDeclaration(false, "x", false, unit, parseLongValue(42, testSection), testSection, testSection)
    val readX = parseVariableRead("x", testSection)
    val nodes: any = luaExpr("{}")
    embedLua("table.insert(nodes, decl)")
    embedLua("table.insert(nodes, readX)")
    checkNames(nodes, ct, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 0)
}

test("checkNames: undefined variable produces UnrecognizedName") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val messages: any = luaExpr("{}")

    val readY = parseVariableRead("undefinedVar", testSection)
    val nodes: any = luaExpr("{}")
    embedLua("table.insert(nodes, readY)")
    checkNames(nodes, ct, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 1)
    val msg: any = luaExpr("messages[1]")
    val code: string = luaExpr("msg.code")
    assertEqual(code, "UNRECOGNIZED_NAME")
}

test("checkNames: variable from compileTables is recognized") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val sym = newSymbol("test", "pkg", "existingVar", tInt, true, false)
    ctDefineSymbol(ct, sym)
    val messages: any = luaExpr("{}")

    val readX = parseVariableRead("existingVar", testSection)
    val nodes: any = luaExpr("{}")
    embedLua("table.insert(nodes, readX)")
    checkNames(nodes, ct, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 0)
}

test("checkNames: aliased package is recognized") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val imp: any = { moduleName: "std", packageName: "math", packageAlias: "m", entries: [], section: unit }
    val ct = newCompileTables(pkg, unit, [imp])
    val messages: any = luaExpr("{}")

    val readM = parseVariableRead("m", testSection)
    val nodes: any = luaExpr("{}")
    embedLua("table.insert(nodes, readM)")
    checkNames(nodes, ct, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 0)
}

test("checkNames: lambda creates new scope for args") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val messages: any = luaExpr("{}")

    // Lambda { a -> a }
    val args: any = luaExpr("{}")
    val arg = newFormalArgument("a", unit, unit, testSection)
    embedLua("table.insert(args, arg)")
    val lambdaBody: any = luaExpr("{}")
    val readA = parseVariableRead("a", testSection)
    embedLua("table.insert(lambdaBody, readA)")
    val lambda = parseLambda(args, lambdaBody, testSection)

    val nodes: any = luaExpr("{}")
    embedLua("table.insert(nodes, lambda)")
    checkNames(nodes, ct, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 0)
}

test("checkNames: lambda arg not visible outside") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val messages: any = luaExpr("{}")

    // Lambda { a -> unit }, then read a outside
    val args: any = luaExpr("{}")
    val arg = newFormalArgument("lambdaArg", unit, unit, testSection)
    embedLua("table.insert(args, arg)")
    val lambdaBody: any = luaExpr("{}")
    embedLua("table.insert(lambdaBody, parseUnitValue(testSection))")
    val lambda = parseLambda(args, lambdaBody, testSection)

    val readArg = parseVariableRead("lambdaArg", testSection)
    val nodes: any = luaExpr("{}")
    embedLua("table.insert(nodes, lambda)")
    embedLua("table.insert(nodes, readArg)")
    checkNames(nodes, ct, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 1)
}

test("checkNames: for loop vars are scoped") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val messages: any = luaExpr("{}")

    // for i in iter { i } — i is accessible inside
    val iter = parseVariableRead("iter", testSection)
    // iter is undefined, so define it
    val declIter = parseNameDeclaration(false, "iter", false, unit, parseCreateArray(luaExpr("{}"), testSection), testSection, testSection)
    val readI = parseVariableRead("i", testSection)
    val forBody = parseBlock([readI], testSection)
    val forNode = parseFor(["i"], iter, unit, unit, forBody, testSection)

    // After for, i should not be accessible
    val readIAfter = parseVariableRead("i", testSection)

    val nodes: any = luaExpr("{}")
    embedLua("table.insert(nodes, declIter)")
    embedLua("table.insert(nodes, forNode)")
    embedLua("table.insert(nodes, readIAfter)")
    checkNames(nodes, ct, messages)
    val msgCount: int = luaExpr("#messages")
    // readIAfter should produce 1 message
    assertEqual(msgCount, 1)
}

test("checkNames: func name is visible, args are scoped") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val messages: any = luaExpr("{}")

    // fn myFunc(p) { p }
    val args: any = luaExpr("{}")
    val arg = newFormalArgument("p", unit, unit, testSection)
    embedLua("table.insert(args, arg)")
    val readP = parseVariableRead("p", testSection)
    val funcBody = parseBlock([readP], testSection)
    val funcNode = parseFuncWithName(false, "myFunc", [], args, unit, funcBody, testSection)

    // After func, myFunc is visible but p is not
    val readFunc = parseVariableRead("myFunc", testSection)
    val readPAfter = parseVariableRead("p", testSection)

    val nodes: any = luaExpr("{}")
    embedLua("table.insert(nodes, funcNode)")
    embedLua("table.insert(nodes, readFunc)")
    embedLua("table.insert(nodes, readPAfter)")
    checkNames(nodes, ct, messages)
    val msgCount: int = luaExpr("#messages")
    // p after func should produce 1 message
    assertEqual(msgCount, 1)
}

test("checkNames: effect definition adds name") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val messages: any = luaExpr("{}")

    val effDef = parseEffectDefinition(false, "myEffect", [], [], unit, testSection)
    val readEff = parseVariableRead("myEffect", testSection)
    val nodes: any = luaExpr("{}")
    embedLua("table.insert(nodes, effDef)")
    embedLua("table.insert(nodes, readEff)")
    checkNames(nodes, ct, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 0)
}

test("checkNames: handle cases have resume and arg names") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val messages: any = luaExpr("{}")

    // handle { unit } with { eff(x) -> resume }
    val hBody = parseUnitValue(testSection)
    val readResume = parseVariableRead("resume", testSection)
    val readX = parseVariableRead("x", testSection)
    val caseBody = parseBlock([readResume, readX], testSection)
    val hCase = newParseHandleCase("eff", ["x"], caseBody, testSection)
    val handleNode = parseHandle(hBody, [hCase], testSection)

    val nodes: any = luaExpr("{}")
    embedLua("table.insert(nodes, handleNode)")
    checkNames(nodes, ct, messages)
    val msgCount: int = luaExpr("#messages")
    // "eff" is the effect name (not a variable read), resume and x should be defined in case scope
    assertEqual(msgCount, 0)
}

// =========================================================================
// visibilityCheck tests
// =========================================================================

test("visibilityCheck: local access is fine") {
    val messages: any = luaExpr("{}")
    val expr = variableAccessExpr(localTarget("x"), testSection)
    expr.setExprType(tInt)
    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, expr)")
    visibilityCheck(exprs, "mymod", unit, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 0)
}

test("visibilityCheck: same module package access is fine") {
    val messages: any = luaExpr("{}")
    val expr = variableAccessExpr(packageTarget("mymod", "pkg", "foo"), testSection)
    expr.setExprType(tInt)
    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, expr)")
    visibilityCheck(exprs, "mymod", unit, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 0)
}

test("visibilityCheck: cross-module non-public access produces error") {
    val ns: any = luaExpr("{}")
    embedLua("ns.getSymbol = function(mod, pkg, name) return { moduleName = mod, packageName = pkg, name = name, symbolType = nil, isPublic = false, isMutable = false } end")
    val messages: any = luaExpr("{}")

    val expr = variableAccessExpr(packageTarget("othermod", "otherpkg", "secret"), testSection)
    expr.setExprType(tInt)
    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, expr)")
    visibilityCheck(exprs, "mymod", ns, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 1)
    val msg: any = luaExpr("messages[1]")
    val code: string = luaExpr("msg.code")
    assertEqual(code, "CANNOT_ACCESS_INTERNAL")
}

test("visibilityCheck: cross-module public access is fine") {
    val ns: any = luaExpr("{}")
    embedLua("ns.getSymbol = function(mod, pkg, name) return { moduleName = mod, packageName = pkg, name = name, symbolType = nil, isPublic = true, isMutable = false } end")
    val messages: any = luaExpr("{}")

    val expr = variableAccessExpr(packageTarget("othermod", "otherpkg", "pubFn"), testSection)
    expr.setExprType(tInt)
    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, expr)")
    visibilityCheck(exprs, "mymod", ns, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 0)
}

// =========================================================================
// fnCallCheck tests
// =========================================================================

test("fnCallCheck: calling a function type is fine") {
    val messages: any = luaExpr("{}")
    val fnType = functionType([tInt, tString], [], 0)
    val callee = variableAccessExpr(localTarget("f"), testSection)
    callee.setExprType(fnType)
    val arg = atomExpr("42", tInt, testSection)
    val callExpr = fnCallExpr(callee, [arg], testSection)
    callExpr.setExprType(tString)

    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, callExpr)")
    fnCallCheck(exprs, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 0)
}

test("fnCallCheck: calling a non-function type produces error") {
    val messages: any = luaExpr("{}")
    val callee = variableAccessExpr(localTarget("x"), testSection)
    callee.setExprType(tInt)
    val arg = atomExpr("42", tInt, testSection)
    val callExpr = fnCallExpr(callee, [arg], testSection)
    callExpr.setExprType(tInt)

    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, callExpr)")
    fnCallCheck(exprs, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 1)
    val msg: any = luaExpr("messages[1]")
    val code: string = luaExpr("msg.code")
    assertEqual(code, "NOT_A_FUNCTION")
}

test("fnCallCheck: nested fn_call checks callee types") {
    val messages: any = luaExpr("{}")
    // Inner call: callee is int (bad)
    val innerCallee = variableAccessExpr(localTarget("x"), testSection)
    innerCallee.setExprType(tInt)
    val innerCall = fnCallExpr(innerCallee, [], testSection)
    innerCall.setExprType(tInt)

    // Outer call: callee is fn (good)
    val fnType = functionType([tInt, tString], [], 0)
    val outerCallee = variableAccessExpr(localTarget("f"), testSection)
    outerCallee.setExprType(fnType)
    val outerCall = fnCallExpr(outerCallee, [innerCall], testSection)
    outerCall.setExprType(tString)

    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, outerCall)")
    fnCallCheck(exprs, messages)
    val msgCount: int = luaExpr("#messages")
    // Only inner call should produce an error
    assertEqual(msgCount, 1)
}

// =========================================================================
// immutabilityCheck tests
// =========================================================================

test("immutabilityCheck: assignment to mutable is fine") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val sym = newSymbol("test", "pkg", "x", tInt, true, true)
    ctDefineSymbol(ct, sym)
    val messages: any = luaExpr("{}")

    val value = atomExpr("42", tInt, testSection)
    val expr = assignmentExpr(localTarget("x"), value, testSection)
    expr.setExprType(tInt)
    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, expr)")
    immutabilityCheck(exprs, "test", "pkg", ct, unit, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 0)
}

test("immutabilityCheck: assignment to immutable produces error") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val sym = newSymbol("test", "pkg", "y", tInt, true, false)
    ctDefineSymbol(ct, sym)
    val messages: any = luaExpr("{}")

    val value = atomExpr("42", tInt, testSection)
    val expr = assignmentExpr(localTarget("y"), value, testSection)
    expr.setExprType(tInt)
    val exprs: any = luaExpr("{}")
    embedLua("table.insert(exprs, expr)")
    immutabilityCheck(exprs, "test", "pkg", ct, unit, messages)
    val msgCount: int = luaExpr("#messages")
    assertEqual(msgCount, 1)
    val msg: any = luaExpr("messages[1]")
    val code: string = luaExpr("msg.code")
    assertEqual(code, "CANNOT_CHANGE_IMMUTABLE")
}

test("immutabilityCheck: package target same module") {
    val pkg: any = { moduleName: "test", packageName: "pkg" }
    val ct = newCompileTables(pkg, unit, [])
    val sym = newSymbol("test", "pkg", "z", tInt, true, false)
